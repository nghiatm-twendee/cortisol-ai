model JiraIssue {
  id        String  @id @map("id") @db.VarChar(50) // Jira issue.id
  key       String  @map("key")
  self      String  @map("self")
  summary   String  @map("summary")
  // description String?   @map("description")
  status    String? @map("status") // issue.fields.status.name
  issueType String? @map("issueType") // issue.fields.issuetype.name
  isSubtask Boolean @default(false) // issuetype.subtask

  projectId String @map("projectId")
  // reporterId  String?   @map("reporterId")
  // assigneeId  String?   @map("assigneeId")
  // created     DateTime? @map("created")
  // updated     DateTime? @map("updated")

  // ===== Hierarchy =====
  parentId String?    @map("parentId") @db.VarChar(50)
  parent   JiraIssue? @relation("IssueHierarchy", fields: [parentId], references: [id])

