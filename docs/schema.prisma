// Action được tạo từ form đánh giá
model EvaluationAction {
  id String @id @default(cuid())

  evaluationId String            @map("evaluation_id")
  evaluation   ProjectEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  // Nội dung action
