// Assignee của action (many-to-many relationship)
model EvaluationActionAssignee {
  id String @id @default(cuid())

  actionId String           @map("action_id")
  action   EvaluationAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  // Nhân sự được assign
  assigneeId String          @map("assignee_id")
  assignee   EmployeeProfile @relation("ActionAssignee", fields: [assigneeId], references: [id])

  // Trạng thái đọc của assignee này
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([actionId, assigneeId]) // Một action không assign trùng người
  @@index([assigneeId, isRead]) // Query notifications cho user
  @@index([actionId])
  @@map("evaluation_action_assignees")
}

