// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== USER MANAGEMENT =====
model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  username           String     @unique
  password           String
  firstName          String?
  lastName           String?
  avatar             String?
  phone              String?
  status             UserStatus @default(ACTIVE)
  deleted            Boolean    @default(false)
  role               String? // Auto-synced colon-separated roles with scopes (e.g., "admin:global:hr-manager:department-hr")
  specialPermissions Json? // examp {"viewContract":true,"addContract":false, "editContract":true,"menu_access_employees":true,"group_menu_hr":true}

  emailNotiActive Boolean @default(true)

  processId String? // Process ID for workflow management
  // Relations
  profile   EmployeeProfile?

  // File Management Relations
  uploadedFiles  File[]   @relation("FileUploader") // Files uploaded by this user
  createdFolders Folder[] @relation("FolderCreator") // Folders created by this user

  // RBAC Relations
  // roleAssignments UserRoleAssignment[] //todo: remove

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processUsers            ProcessUser[]
  TimeApplicationApproval TimeApplicationApproval[]
  PayrollSummary          PayrollSummary[]
  VoucherApproval         VoucherApproval[]
  Voucher                 Voucher[]                 @relation("VoucherCreator")
  // PurchaseWorkflowApproval PurchaseWorkflowApproval[]
  StepAssignee            ProcessStep[]             @relation("StepAssignee")
  StepCompleter           ProcessStep[]             @relation("StepCompleter")
  SettlementForm          SettlementForm[]
  Process                 Process[]                 @relation("ProcessCreator")
  ShiftSchedule           ShiftSchedule[]

  // Link to other system
  links UserLink[]

  // Comments
  comments        Comment[]
  commentMention  CommentMention[]
  commentReaction CommentReaction[]
  refreshTokens   RefreshToken[]
  activityLogs    ActivityLog[]

  entityAuditLogs EntityAuditLog[] @relation("EntityAuditor")

  // Sourcing Candidates Relations
  sourcing_candidates sourcing_candidate[] @relation("CandidateOwner")
  createdCandidates   sourcing_candidate[] @relation("CandidateCreator")

  // Candidate Owner Change Request Relations
  ownerChangeRequestsFrom CandidateOwnerChangeRequest[] @relation("FromOwner")
  ownerChangeRequestsTo   CandidateOwnerChangeRequest[] @relation("ToOwner")

  receivedAlerts EvaluationAlert[] @relation("AlertRecipient")

  createdEvaluationActions EvaluationAction[] @relation("ActionCreator")

  // Recruitment Deal Relations
  createdDeals         RecruitmentDeal[]         @relation("DealCreator")
  submittedCandidates  DealCandidateSubmission[] @relation("CandidateSubmitter")
  submissionStatusLogs SubmissionStatusLog[]     @relation("StatusLogPerformer")
  dealHistories        DealHistory[]             @relation("DealHistoryCreator")
  dealAuditLogs        DealAuditLog[]            @relation("DealAuditor")

  recruitmentDealFollowers RecruitmentDeal[] @relation("UserRecruitmentDealFollower")

  competencyAssessments CompetencyAssessment[] @relation("CompetencyAssessor")

  // CRM Relations
  createdCrmCompanies  CrmCompany[]          @relation("CrmCompanyCreator")
  createdCrmLeads      CrmLead[]             @relation("CrmLeadCreator")
  createdCrmDeals      CrmDeal[]             @relation("CrmDealCreator")
  crmDealFollowers     CrmDealFollower[]     @relation("CrmDealFollower")
  createdCrmFollowUps  CrmFollowUp[]         @relation("CrmFollowUpCreator")
  crmFollowUpFollowers CrmFollowUpFollower[] @relation("CrmFollowUpFollower")
  createdCrmComments   CrmComment[]          @relation("CrmCommentCreator")
  crmNotifications     CrmNotification[]     @relation("CrmNotificationRecipient")

  @@map("users")
}

enum UserStatus {
  TEMPORARY // Temporary users, e.g., for onboarding
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  MANAGEMENT
  EMPLOYEE
  PM
  HR
  ACCOUNTING
  ACCOUNTING_HR
  BOD
  ADMIN
  SALES // ✅ NEW - Sales role
}

model RefreshToken {
  id         String  @id @default(cuid())
  token      String  @unique
  deviceId   String? // e.g., UUID of the device
  deviceType String? // e.g., "iOS", "Android", "Web"
  ipAddress  String?

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// ===== USER LINK =====
model UserLink {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Enum cho hệ thống ngoài
  externalSystem   ExternalSystem
  externalUserId   String
  externalUsername String?
  metadata         Json?
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([externalSystem, userId, externalUserId])
  @@index([userId])
  @@index([externalSystem])
}

enum ExternalSystem {
  PORTAL_OUTSOURCING
  TELEGRAM
  JIRA
  GOOGLE_CALENDAR
}

// ===== CATEGORIES =====
enum CategoryType {
  DEPARTMENT // Phòng ban
  POSITION // Vị trí
  JOB_TITLE // Chức vụ
  WORKPLACE // Nơi làm việc
  // LABOR_TYPE // Loại lao động
  // MILITARY_SERVICE // Nghĩa vụ quân sự
  // MARITAL_STATUS // Tình trạng hôn nhân
  // PASSPORT_TYPE // Loại hộ chiếu
  BANK // Ngân hàng
  LEVEL // Cấp bậc:  fresher, intern, Junior (có-không có eng), mid và senior (same)
  FAMILY_RELATIONSHIP // Mối quan hệ gia đình
  EDUCATION_TYPE // Hình thức đào tạo: chính quy, tại chức, từ xa
  INSURANCE_BENEFIT_TYPE // Loại chế độ bảo hiểm
  RECEIPT_PARTNER_VOUCHER // Đối tác (cho phiếu chi/thu)
  PAYMENT_PARTNER_VOUCHER // Đối tác (cho phiếu chi/thu)
  OFFBOARDING_CHECKLIST // checklist offboarding
  OFFBOARDING_REASON // lý do offboarding
  FAMILY_DOCUMENT_TYPE // Số/Loại giấy tờ: (1 Sổ hộ khẩu, 2 Sổ tạm trú, 3 Giấy tạm trú, 4 Sổ UBND, 5 Khác)
  EXPENSE_CATEGORY // Danh mục khoản mục chi
  EXPENSE_OBJECT // Danh mục đối tượng chi
  REVENUE_CATEGORY // Danh mục khoản mục thu
  REVENUE_OBJECT // Danh mục đối tượng thu

  // ===== TECH =====
  TECH_GROUP // Nhóm tech stack
  TECH_SKILL // Kỹ năng cụ thể
  PROJECT_POSITION // Vị trí dự án

  COUNTRY // Quốc gia
  DOMAIN // Lĩnh vực hoạt động của công ty/deal
}

model Category {
  id          String       @id @default(cuid())
  name        String
  code        String
  parentId    String? // Parent category ID for hierarchical categories
  type        CategoryType // Loại danh mục
  description String? // Mô tả
  isActive    Boolean      @default(true) // Trạng thái hoạt động
  orderIndex  Int? // Thứ tự hiển thị

  deleted   Boolean  @default(false)
  createdBy String? // Người tạo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, code])
  @@map("categories")
}

// ===== EMPLOYEE PROFILE =====
model EmployeeProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 1. Thông tin cá nhân
  employeeCode         String            @unique // Mã nhân sự (tự nhảy)
  attendanceCode       String? // Mã chấm công (nhập tay sau khi đăng kí vân tay)
  fullName             String? // user.firstName + user.lastName
  birthDate            DateTime?
  gender               Gender?
  militaryService      MilitaryService? // nghĩa vụ quân sự
  birthPlace           String? // Nơi sinh
  hometown             String? // Nguyên quán
  nationality          String? // Quốc tịch
  maritalStatus        MaritalStatus?
  ethnicity            String? // Dân tộc
  religion             String? // Tôn giáo
  personalTaxCode      String? // MST cá nhân
  joinDate             DateTime? // Ngày vào
  officialContractDate DateTime? // Ngày kí HĐLĐ chính thức
  directManagerId      String? // Người QL trực tiếp
  directManager        EmployeeProfile?  @relation("DirectManager", fields: [directManagerId], references: [id])
  subordinates         EmployeeProfile[] @relation("DirectManager")
  laborType            LaborType? // Loại lao động: In-house, CTV, vendor

  supplierId String? // Nếu là vendor thì liên kết với vendor nào
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  // 2. Thông tin CMT/CC/CCCD/Hộ chiếu
  citizenId           String?
  citizenIdIssueDate  DateTime?
  citizenIdIssuePlace String?
  citizenIdFrontPhoto String? // URL ảnh CCCD mặt trước
  citizenIdBackPhoto  String? // URL ảnh CCCD mặt sau
  passportType        PassportType?
  passportNumber      String?
  passportIssueDate   DateTime?
  passportExpiryDate  DateTime?
  passportIssuePlace  String?
  passportPhoto       String? // URL ảnh hộ chiếu

  // 3. Thông tin ngân hàng
  bankAccount     String?
  bankAccountName String?
  bankCode        String? // code for category with type BANK
  bankName        String?
  bankBranch      String?

  // 4. Thông tin liên hệ
  phone            String?
  personalEmail    String? // Email cá nhân
  permanentAddress String? // Thường trú
  currentAddress   String? // Chỗ ở hiện nay

  // Start: Contract info
  // Temporary for onboarding process to use for contract signing
  // Work info
  department String? // Phòng ban: category with type DEPARTMENT
  position   String? // Vị trí: category with type POSITION
  jobTitle   String? // chức vụ: category with type JOB_TITLE
  level      String? // cấp bậc: category with type LEVEL
  // workplace    String? // nơi làm việc
  // workingHours String? // giờ làm việc

  // Salary info
  // basicSalary Float? // Lương cơ bản todo:remove
  // End: Contract info
  hireDate DateTime? // Ngày vào làm

  // Profile photo
  profilePhoto String? // Ảnh đại diện

  // Relations
  familyMembers     FamilyMember[]
  educationHistory  EducationHistory[]
  workExperience    WorkExperience[]
  certificates      Certificate[]
  contracts         Contract[]
  insuranceInfo     InsuranceInfo?
  healthRecords     HealthRecord[]
  // attachments       EmployeeAttachment[] // todo: remove
  // other
  probationDuration String? // Thời gian thử việc

  vehicleNumber String? // Biển số xe
  vehicleInfo   String? // Loại xe/Màu xe

  deleted Boolean @default(false)

  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  InsuranceHistory         InsuranceHistory[]
  BenefitHistory           BenefitHistory[]
  DailyAttendanceRecord    DailyAttendanceRecord[]
  MonthlyAttendanceSummary MonthlyAttendanceSummary[]
  TimeApplication          TimeApplication[]
  AttendanceTimeSegment    AttendanceTimeSegment[]
  leaveBalances            LeaveBalance[]
  emergencyContact         EmergencyContact?
  PayrollEmployee          PayrollEmployee[]
  OffboardingWorkflow      OffboardingWorkflow[]
  ShiftAssignment          ShiftAssignment[]
  VoucherDetail            VoucherDetail[]

  // Project relations
  projectMembers         ProjectMember[] @relation("EmployeeProjectMembership")
  followerProjectMembers ProjectMember[] @relation("EmployeeProjectMemberFollower")
  projects               Project[]       @relation("FollowerProject")
  clientFlowerProjects   Project[]       @relation("ClientFollowerProject")

  // Candidate project follower relations
  followerCandidateProjects CandidateProject[] @relation("EmployeeCandidateProjectFollower")

  // Recruitment deal submissions (when employee is submitted to deal)
  dealSubmissions DealCandidateSubmission[]

  // NEW: Relations cho đánh giá
  evaluations ProjectEvaluation[] @relation("Evaluator") // Người thực hiện đánh giá
  evaluatedIn EvaluationMember[]  @relation("EvaluatedEmployee")

  // Action notifications
  assignedActions EvaluationActionAssignee[] @relation("ActionAssignee") // Action được giao

  competencyAssessments CompetencyAssessment[]

  // createdActions  EvaluationActionNotification[] @relation("ActionCreator") // Action đã tạo
  @@map("employee_profiles")
}

enum MilitaryService {
  COMPLETED // đã đi
  NOT_YET // chưa đi
  EXEMPT // không phải đi
}

enum MaritalStatus {
  SINGLE // độc thân
  MARRIED // kết hôn
  DIVORCED // ly hôn
}

enum LaborType {
  IN_HOUSE // In-house
  CONTRACTOR // CTV
  VENDOR // vendor
}

enum PassportType {
  ORDINARY // phổ thông
  OFFICIAL // công vụ
  DIPLOMATIC // ngoại giao
}

// 5. Thông tin gia đình, người phụ thuộc
model FamilyMember {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  relationship        String // Mối quan hệ: Category with type FAMILY_RELATIONSHIP
  fullName            String
  birthDate           DateTime?
  phone               String?
  citizenId           String?
  citizenIdIssueDate  DateTime?
  citizenIdIssuePlace String?
  isDependent         Boolean   @default(false) // Phụ thuộc
  dependentFromDate   DateTime?
  dependentToDate     DateTime?
  taxCode             String?
  notes               String?
  isEmergency         Boolean   @default(false) // Liên hệ khẩn cấp

  // ====== Bổ sung theo yêu cầu ======
  nationality      String? // Quốc tịch
  ethnicity        String? // Dân tộc
  birthAddress     String? // Địa chỉ khai sinh (Thôn/xóm/tổ - Xã/Phường - Tỉnh/TP)
  householdAddress String? // Địa chỉ hộ khẩu (Thôn/xóm/tổ - Xã/Phường - Tỉnh/TP)

  documentType String? // Category with type FAMILY_DOCUMENT_TYPE. Số/Loại giấy tờ: (1 Sổ hộ khẩu, 2 Sổ tạm trú, 3 Giấy tạm trú, 4 Sổ UBND, 5 Khác)
  // householdRelation String? // Quan hệ với chủ hộ (00 chủ hộ, 01 Vợ, 02 Chồng, 03 Bố, ...)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("family_members")
}

model EmergencyContact {
  id         String          @id @default(cuid())
  employeeId String          @unique
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  relationship String? // Mối quan hệ: Category with type FAMILY_RELATIONSHIP
  fullName     String?
  phone        String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emergency_contacts")
}

// 6. Quá trình học tập
model EducationHistory {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  fromDate      DateTime?
  toDate        DateTime?
  educationType String? // Hình thức đào tạo: Category with type EDUCATION_TYPE
  major         String? // Chuyên ngành
  degree        String? // Trình độ
  institution   String? // Nơi đào tạo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("education_history")
}

// 8. Kinh nghiệm làm việc
model WorkExperience {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  fromMonth      Int
  fromYear       Int
  toMonth        Int
  toYear         Int
  company        String
  position       String
  reference      String? // Người tham chiếu
  referencePhone String?
  jobDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_experience")
}

// 9. Chứng chỉ
model Certificate {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  certificateNumber   String
  issuingOrganization String
  certificateType     String
  version             String?
  issueNumber         String?
  validFrom           DateTime
  validTo             DateTime?
  attachment          String? // File đính kèm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("certificates")
}

// ===== BẢO HIỂM =====
enum InsuranceStatus {
  ACTIVE // Đang tham gia
  FINALIZED // Đã chốt
  UNFINALIZED // Chưa chốt
  NO_BOOK // Chưa có sổ
}

model InsuranceInfo {
  id         String          @id @default(cuid())
  employeeId String          @unique
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // 1. Thông tin bảo hiểm
  insuranceBookNumber String? // Số sổ bảo hiểm
  bookStatus          InsuranceStatus? @default(UNFINALIZED) // Trạng thái sổ :  Đang tham gia, Chưa tham gia, Đã báo giảm
  unfinalizedReason   String? // Lý do chưa chốt sổ
  payingEntity        String? // Pháp nhân đóng
  healthInsuranceCard String? // Số thẻ BHYT
  provinceCode        String? // Mã tỉnh cấp
  healthcareProvider  String? // ĐK khám chữa bệnh

  // 2. Nghiệp vụ báo tăng
  profileCompletedDate  DateTime? // Nhân viên hoàn thiện hồ sơ
  healthCardReceiveDate DateTime? // Ngày nhận thẻ y tế
  healthCardReturnDate  DateTime? // Ngày trả thẻ y tế

  // 3. Nghiệp vụ báo giảm
  insuranceBookReceiveDate DateTime? // Ngày nhận sổ BH từ NLĐ
  profileFinalizedDate     DateTime? // Nhân sự hoàn thiện hồ sơ
  finalBookReceiveDate     DateTime? // Ngày nhận sổ BH đã chốt
  bookReturnToEmployeeDate DateTime? // Ngày trả sổ cho NLĐ

  // Relations
  // insuranceHistory InsuranceHistory[]
  // benefitHistory   BenefitHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("insurance_info")
}

// 4. Lịch sử đóng bảo hiểm
// enums cho dropdown
enum InsuranceType {
  MANDATORY // Bắt buộc
  VOLUNTARY // Tự nguyện
  NOT_PARTICIPATING // Không tham gia
}

model InsuranceHistory {
  id         String          @id @default(cuid())
  // insuranceInfoId String
  // insuranceInfo   InsuranceInfo @relation(fields: [insuranceInfoId], references: [id], onDelete: Cascade)
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  fromMonth      Int
  fromYear       Int
  toMonth        Int?
  toYear         Int?
  type           InsuranceType // Hình thức
  reason         String? // Lý do
  payingEntity   String? // Pháp nhân
  insuranceLevel Float? // Mức đóng bảo hiểm
  companyPaid    Float? // Cty đóng
  employeePaid   Float? // người LĐ đóng
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("insurance_history")
}

// 5. Lịch sử giải quyết chế độ
model BenefitHistory {
  id         String          @id @default(cuid())
  // insuranceInfoId String
  // insuranceInfo   InsuranceInfo @relation(fields: [insuranceInfoId], references: [id], onDelete: Cascade)
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  benefitType                 String // Loại chế độ: Category with type INSURANCE_BENEFIT_TYPE
  applicationReceiveDate      DateTime? // Ngày nhận hồ sơ
  procedureCompleteDate       DateTime? // Ngày hoàn thiện thủ tục
  insurancePaymentReceiveDate DateTime? // Ngày nhận tiền BH trả
  benefitPaymentDate          DateTime? // Ngày trả chế độ
  amount                      Float? // Số tiền
  notes                       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("benefit_history")
}

// ===== SỨC KHỎE =====
model HealthRecord {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  checkupDate  DateTime
  healthStatus String?
  notes        String?
  attachment   String? // File import khi khám sức khỏe định kì

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("health_records")
}

// ===== PHÂN CA VÀ CHẤM CÔNG =====

// Cài đặt ca làm việc
model WorkShift {
  id String @id @default(cuid())

  shiftCode              String  @unique // Mã ca
  shiftName              String // Tên ca
  // shiftType             ShiftType // Loại ca
  startTime              String // Giờ bắt đầu (format HH:mm)
  endTime                String // Giờ kết thúc (format HH:mm)
  breakStartTime         String // Giờ bắt đầu (format HH:mm)
  breakEndTime           String // Giờ kết thúc (format HH:mm)
  autoAttendanceEnabled  Boolean @default(false)
  totalWorkingHours      Float? // Tổng giờ làm việc
  totalWorkingDays       Float? // Tổng công làm việc của ca này
  allowEarlyLeaveMinutes Float? // ví dụ 60 hay 120

  isActive Boolean @default(true)

  // Relations
  shiftAssignments ShiftAssignment[]
  // timeAttendance   TimeAttendance[]

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  dailyAttendanceRecord DailyAttendanceRecord[]
  AttendanceTimeSegment AttendanceTimeSegment[]

  @@map("work_shifts")
}

enum ShiftType {
  ADMINISTRATIVE // hành chính
  PART_TIME // part time
  REMOTE // remote
  FAMILY_ADMIN // hành chính gia đình
}

// Phân ca
model ShiftSchedule {
  id String @id @default(cuid())

  title        String // Tiêu đề
  scheduleType ScheduleType // Kiểu phân ca
  // shiftType    ShiftType // Loại ca //todo remove
  approverId   String? // Người duyệt
  approver     User?        @relation(fields: [approverId], references: [id])
  comments     String?

  // Lặp lại
  repeatType RepeatType // Loại lặp
  // repeatDays String? // Ngày lặp (JSON array)// todo: remove
  fromDate   DateTime? // Từ ngày
  toDate     DateTime? // Đến ngày

  uploadFile String[] // File upload

  status   ScheduleStatus @default(PENDING)
  isActive Boolean        @default(true) // Trạng thái hoạt động

  // Relations
  assignments ShiftAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shift_schedules")
}

enum ScheduleType {
  DEPARTMENT // phòng ban
  INDIVIDUAL // cá nhân
}

enum RepeatType {
  DAILY // theo ngày
  WEEKLY // theo tuần
  DATE_RANGE // theo khoảng ngày
  SPECIFIC_DATES // những ngày cụ thể
}

enum ScheduleStatus {
  PENDING // chờ duyệt
  APPROVED // đã duyệt
  REJECTED // từ chối
}

// Chi tiết phân ca
model ShiftAssignment {
  id String @id @default(cuid())

  scheduleId String
  schedule   ShiftSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  employeeId     String?
  employee       EmployeeProfile? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  departmentCode String?

  shiftId String
  shift   WorkShift @relation(fields: [shiftId], references: [id])

  assignDate DateTime? // Ngày phân ca DAILY,DATE_RANGE, SPECIFIC_DATES
  dayOfWeek  Int? // Thứ (2-8, CN=8) => 0-6 by javascript

  @@unique([scheduleId, employeeId, departmentCode, assignDate])
  @@map("shift_assignments")
}

// ===== NGÀY NGHỈ =====
model Holiday {
  id String @id @default(cuid())

  reason      String // lý do nghỉ
  holidayType HolidayType // Loại nghỉ

  // Relations
  holidayDates HolidayDate[]

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("holidays")
}

enum HolidayType {
  NATIONAL // nghỉ lễ
  EVENT // nghỉ sự kiện
  COMPENSATORY // nghỉ bù
  IRREGULAR // nghỉ bất thường
}

model HolidayDate {
  id String @id @default(cuid())

  holidayId String
  holiday   Holiday @relation(fields: [holidayId], references: [id], onDelete: Cascade)

  holidayDate DateTime // Ngày nghỉ
  startTime   String? // Bắt đầu giờ (cho sự kiện/bất thường)
  endTime     String? // Kết thúc giờ (cho sự kiện/bất thường)
  isPaid      Boolean  @default(true) // Tính công
  isRecurring Boolean  @default(false) // Lặp hàng năm (cho nghỉ lễ)

  // Áp dụng cho
  departments String[] // Phòng ban
  positions   String[] // Vị trí
  jobTitles   String[] // Chức vụ

  @@map("holiday_dates")
}

// Bảng tổng hợp phép
model LeaveBalance {
  id String @id @default(cuid())

  employeeId String
  year       Int

  // Tổng phép
  totalLeave   Float // tổng: annualLeave + seniorityLeave + accumulatedTotal
  usedLeave    Float // đã sử dụng
  expiredLeave Float @default(0) // hết hạn: Phép luy kế hết hạn= accumulatedTotal - accumulatedUsed được tính sau khi hết hạn
  // remainingLeave Float // tồn cuối: tính toán từ tổng - đã sử dụng - hết hạn

  // Phép ứng
  // advanceLeave Float

  // Phép lũy kế
  accumulatedTotal         Float     @default(0) // tổng nêu = migratedaccumulatedTotal>0  ? migratedaccumulatedTotal :  tính từ số dư năm trước
  accumulatedUsed          Float     @default(0) // sử dụng migratedAccumulatedUsed + tính từ đơn từ
  // accumulatedExpired     Float // hết hạn
  accumulatedExpiredDate   DateTime? // ngày hết hạn: mặc định 32/03/year của năm đó
  // accumulatedRemaining   Float // tồn cuối : tính toán từ tổng - đã sử dụng
  migratedAccumulatedTotal Float     @default(0) // tổng phép lũy kế tinh dựa vào migrate
  migratedAccumulatedUsed  Float     @default(0) // đã dùng phép lũy kế trước khi migrate

  // Phép thâm niên
  seniorityLeave        Float @default(0) // hiện tại
  seniorityUsed         Float @default(0) // sử dụng migratedSeniorityUsed + tính từ đơn từ
  // seniorityRemaining Float @default(0) // tồn cuối : tính toán từ tổng - đã sử dụng
  migratedSeniorityUsed Float @default(0) // đã dùng phép thâm niên trước khi migrate

  // Phép năm
  annualLeave        Float @default(0) // tổng
  annualUsed         Float @default(0) // sử dụng migratedAnnualUsed + tính từ đơn từ
  // annualRemaining Float // tồn cuối được tính toán từ tổng - đã sử dụng
  migratedAnnualUsed Float @default(0) // đã dùng phép năm trước khi migrate

  // Ghi chú / thông tin migrate
  migratedAt   DateTime?
  migratedNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  employee EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year])
  @@map("leave_balances")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ===== HỢP ĐỒNG =====
model Contract {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // 1. Thông tin chung
  contractCode        String       @unique // mã hợp đồng
  contractType        ContractType // loại hợp đồng
  department          String? // Phòng ban: category with type DEPARTMENT
  position            String? // Vị trí: category with type POSITION
  jobTitle            String? // chức vụ: category with type JOB_TITLE
  level               String? // cấp bậc: category with type LEVEL
  workplace           String? // nơi làm việc
  workingForm         WorkingForm // hình thức làm việc
  validFrom           DateTime // Hiệu lực từ ngày
  validTo             DateTime? // đến ngày
  signDate            DateTime? // ngày kí
  signedBy            String? // người kí
  hasDigitalSignature Boolean      @default(false) // ký số

  // 2. Lương và phụ cấp
  salaryAllowances SalaryAllowance[]

  status ContractStatus @default(EFFECTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contracts")
}

enum ContractType {
  ONE_YEAR // lao động 1 năm
  PROBATION // thử việc
  INDEFINITE // vô thời hạn
  UNDER_12_MONTHS // dưới 12 tháng
  THREE_YEARS // 3 năm
  CONTRACTOR // CTV
  APPRENTICESHIP // học việc
}

enum WorkingForm {
  FULL_TIME
  PART_TIME
  CONTRACTOR
}

enum ContractStatus {
  // DRAFT // bản nháp todo: remove
  EFFECTIVE // đang hiệu lực
  NOT_EFFECTIVE // chưa hiệu lực todo: remove
  TERMINATED // đã thanh lý
  // EXPIRED // hết hạn : todo remove
  CANCELLED // Bị hủy bỏ (chưa từng có hiệu lực, khác với terminated)
}

model SalaryAllowance {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  salaryType  SalaryType @default(BASIC_SALARY) // enum
  fromDate    DateTime // từ ngày
  toDate      DateTime? // từ ngày
  notes       String?
  salaryForm  String? // hình thức lương
  amount      Float // số tiền
  description String? // mô tả
  attachment  String? // đính kèm

  isActive  Boolean  @default(true) // Trạng thái hoạt động
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("salary_allowances")
}

enum SalaryType {
  BASIC_SALARY // Lương cơ bản
  ALLOWANCE // Phụ cấp
  // BONUS // Thưởng
  // OVERTIME // Làm thêm giờ
  // OTHER // Khác
}

// ===== REQUESTS SYSTEM =====

enum RequestStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ===== LEAVE MANAGEMENT =====
model TimeApplication {
  id              String           @id @default(cuid())
  employeeId      String
  type            ApplicationType
  leaveType       String? // Mã loại nghỉ: LeaveTypeConfig with code use with applicationType LEAVE
  leaveTypeConfig LeaveTypeConfig? @relation(fields: [leaveType], references: [code], onDelete: NoAction)

  reason            String? // with OFFBOARDING use from Category with type OFFBOARDING_REASON
  description       String?
  attachmentFileIds String[] // File URLs

  // status       AppStatus        @default(PENDING)
  status RequestStatus @default(PENDING)

  waitUpdate Boolean @default(false) // true trong trường hợp đơn từ bị revert về nhân viên để chỉnh sửa

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee                EmployeeProfile           @relation(fields: [employeeId], references: [id])
  ot                      OvertimeApplication[]
  checkin                 CheckinApplication[]
  leaveDate               LeaveDate[]
  TimeApplicationApproval TimeApplicationApproval[]
  ApplicationRelation     ApplicationRelation[]
  OffboardingApplication  OffboardingApplication?
  BusinessTripApplication BusinessTripApplication?
  AttendanceTimeSegment   AttendanceTimeSegment[]

  @@map("time_applications")
}

model TimeApplicationApproval {
  id                String          @id @default(cuid())
  timeApplicationId String
  timeApplication   TimeApplication @relation(fields: [timeApplicationId], references: [id], onDelete: Cascade)

  approverId String
  approver   User   @relation(fields: [approverId], references: [id])

  status   ApprovalStatus @default(PENDING)
  comments String?
  index    Int            @default(0) // Thứ tự duyệt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("time_application_approvals")
}

model ApplicationRelation {
  id            String          @id @default(cuid())
  applicationId String // ID của TimeApplication
  application   TimeApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  relatedType RelatedObjectType // INVOICE, PROJECT, PROCESS...
  relatedId   String // ID thực tế

  description       String?
  attachmentFileIds String[] // File ids
  createdAt         DateTime @default(now())

  @@unique([applicationId, relatedType, relatedId])
  @@map("application_relations")
}

enum ApplicationType {
  LEAVE
  OVERTIME
  CHECKIN
  OFFBOARDING
  BUSINESS_TRIP
}

model LeaveDate {
  id            String          @id @default(cuid())
  applicationId String // ID của TimeApplication
  application   TimeApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  startTime DateTime?
  endTime   DateTime?
  days      Float? // Số ngày nghỉ caclculated from leaveDates

  // use for ANNUAL_LEAVE
  leaveBalanceBefore Float? // Số ngày phép còn lại trước khi nghỉ
  leaveBalanceAfter  Float? // Số ngày phép còn lại sau khi nghỉ

  @@map("leave_dates")
}

enum LeaveUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

model OffboardingApplication {
  id                String   @id @default(cuid())
  timeApplicationId String   @unique
  applicationDate   DateTime @default(now())
  lastWorkingDate   DateTime
  resignationDate   DateTime

  timeApplication TimeApplication @relation(fields: [timeApplicationId], references: [id], onDelete: Cascade)

  @@map("offboarding_applications")
}

model LeaveTypeConfig {
  id          String    @id @default(cuid())
  code        String    @unique // VD: "REMOTE_WOMAN", "SICK_CHILD"
  name        String // VD: "Remote chế độ cho NV nữ"
  description String? // Ghi chú mô tả
  maxDays     Int? // Giới hạn tối đa (theo month/year)
  unit        LeaveUnit // Enum: DAY, MONTH, YEAR
  isPaid      Boolean // Nghỉ có lương không
  genderOnly  Gender? // Enum: MALE, FEMALE, null
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  readOnly    Boolean   @default(false) // Không cho phép chỉnh sửa như ANNUAL_LEAVE

  TimeApplication TimeApplication[]
}

// ===== OT =====
model OvertimeApplication {
  id                String   @id @default(cuid())
  timeApplicationId String
  otDate            DateTime
  startTime         DateTime
  endTime           DateTime
  hours             Float? // Số giờ làm thêm
  note              String? // Ghi chú

  projectId String? // Dự án
  project   JiraProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  timeApplication TimeApplication @relation(fields: [timeApplicationId], references: [id], onDelete: Cascade)

  @@map("overtime_applications")
}

// ===== Checkin/checkout Application ====
model CheckinApplication {
  id                String   @id @default(cuid())
  timeApplicationId String
  checkTime         DateTime
  timestampText     String // raw Ngày giờ dạng text (để hiển thị) yyyyMMddHHmm
  reason            String?

  timeApplication TimeApplication @relation(fields: [timeApplicationId], references: [id], onDelete: Cascade)

  @@map("checkin_applications")
}

// ===== Business Trip Application =====
model BusinessTripApplication {
  id                String              @id @default(cuid())
  timeApplicationId String              @unique
  startTime         DateTime
  endTime           DateTime
  tripType          BusinessTripType // Hình thức: trong nước, nước ngoài, nội bộ
  location          String? // Địa điểm công tác
  reason            BusinessTripReason? // Lý do: hội thảo, khách hàng, công việc khác
  transportMethod   TransportMethod? // Phương tiện: cá nhân, grab, etc.

  timeApplication      TimeApplication       @relation(fields: [timeApplicationId], references: [id], onDelete: Cascade)
  businessTripExpenses BusinessTripExpense[]

  @@map("business_trip_applications")
}

enum BusinessTripType {
  DOMESTIC // Trong nước
  INTERNATIONAL // Nước ngoài
  INTERNAL // Nội bộ
}

enum BusinessTripReason {
  CONFERENCE // Hội thảo
  CLIENT // Khách hàng
  OTHER // Công việc khác
}

enum TransportMethod {
  PERSONAL // Cá nhân
  BOOKED // Đặt xe
}

model BusinessTripExpense {
  id             String   @id @default(cuid())
  businessTripId String
  expenseType    String // Loại phụ phí: đi lại, ăn uống, chỗ ở
  amount         Decimal  @db.Decimal(15, 2) // Số tiền
  description    String? // Mô tả chi tiết
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  businessTripApplication BusinessTripApplication @relation(fields: [businessTripId], references: [id], onDelete: Cascade)

  @@map("business_trip_expenses")
}

// ===== ATTENDANCE =====
// Loại công
model TimeCode {
  id          String   @id @default(cuid())
  code        String   @unique // Ví dụ: "NORMAL", "HOLIDAY", "OT", "LEAVE"
  name        String // Ví dụ: "Công ngày thường", "Công ngày lễ", "Nghỉ phép"
  isPaid      Boolean  @default(true) // Có tính lương
  multiplier  Float    @default(1.0) // Hệ số nhân công (ví dụ: 2.0 cho ngày lễ)
  description String? // Mô tả tùy chọn
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // AttendanceTimeSegment AttendanceTimeSegment[]
  @@map("time_code")
}

model RawAttendanceLog {
  id             String     @id @default(cuid())
  deviceId       String? // ID của máy chấm công
  attendanceCode String // Mã nhân viên từ máy (không phải UUID trong hệ thống)
  timestamp      DateTime // Thời điểm quẹt thẻ/vân tay
  timestampText  String // raw Ngày giờ dạng text (để hiển thị) yyyyMMddHHmm
  direction      Direction? // IN hoặc OUT
  rawData        String? // Dữ liệu thô từ thiết bị (nếu cần)
  syncStatus     SyncStatus @default(PENDING) // Trạng thái xử lý dữ liệu
  syncedAt       DateTime? // Thời điểm hệ thống xử lý xong log này
  isManual       Boolean    @default(false) // tạo bằng tay hay tự động import từ máy chấm công

  timeApplicationId String? // ID của đơn xin phép liên quan (nếu có)

  attendanceRecordId String? // ID của bản ghi chấm công sẽ lưu trữ sau khi xử lý
  attendanceRecord   DailyAttendanceRecord? @relation(fields: [attendanceRecordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([attendanceCode, deviceId, timestampText])
  @@map("raw_attendance_log")
}

enum Direction {
  IN
  OUT
}

enum SyncStatus {
  PENDING // Chưa xử lý
  SYNCED // Đã xử lý thành công
  ERROR // Gặp lỗi khi xử lý
}

model AttendanceTimeSegment {
  id                 String                 @id @default(cuid())
  attendanceRecordId String?
  attendanceRecord   DailyAttendanceRecord? @relation(fields: [attendanceRecordId], references: [id])
  employeeId         String
  employee           EmployeeProfile        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  shiftId String?
  shift   WorkShift? @relation(fields: [shiftId], references: [id])

  date     DateTime
  dateText String // Ngày dạng text (để hiển thị) yyyyMMdd

  startTime DateTime? // Thời điểm bắt đầu block công
  endTime   DateTime? // Thời điểm kết thúc block công

  timeCode String?
  // timeCodeRef TimeCode? @relation(fields: [timeCode], references: [code])

  timeApplicationId String?
  timeApplication   TimeApplication? @relation(fields: [timeApplicationId], references: [id], onDelete: Cascade)

  duration Float // Thời lượng tính công (giờ), = endTime - startTime (sau khi loại trừ nghỉ)
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_time_segment")
}

model DailyAttendanceRecord {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  shiftId String?
  shift   WorkShift? @relation(fields: [shiftId], references: [id])

  isWorkingDay Boolean @default(true)

  date                 DateTime
  dateText             String // Ngày dạng text (để hiển thị) yyyyMMdd
  checkIn              DateTime?
  checkOut             DateTime?
  breakTime            Float? // in minutes
  workHours            Float? // giờ làm việc thực tế tính công chuẩn(đã bao gồm nghỉ phép)
  standardWorkingHours Float     @default(0) // Giờ chuẩn theo công ty
  leavePaidHours       Float? // giờ nghỉ tính lương

  overtime     Float? // in hours
  status       AttendanceStatus @default(ABSENT)
  location     String?
  notes        String?
  isLocked     Boolean          @default(false) // Đã chốt
  timeCode     String? // Mã công (ví dụ: "NORMAL", "HOLIDAY", "OT")
  timeCodeList String[]

  // Audit fields for manual corrections
  lastModifiedBy     String? // User ID người sửa cuối
  lastModifiedReason String? // Lý do sửa đổi
  lastModifiedAt     DateTime? // Thời gian sửa đổi cuối

  lateMinutes       Float? // Số phút đi muộn
  earlyLeaveMinutes Float? // Số phút về sớm
  missedChecks      Int    @default(0) // Số lần quên chấm công

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  attendanceTimeSegment AttendanceTimeSegment[]
  rawAttendanceLog      RawAttendanceLog[]

  @@unique([employeeId, date])
  @@map("daily_attendance_record")
}

model MonthlyAttendanceSummary {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  year  Int
  month Int

  // Ngày công sử dung để tính LƯƠNG CƠ BẢN
  actualWorkingDays   Float @default(0) // Ngày công thực tế
  standardWorkingDays Float @default(0) // Số công chuẩn

  // GIỜ LÀM VIỆC
  actualWorkingHours   Float @default(0) // Tổng giờ làm thực tế tính công chuẩn
  standardWorkingHours Float @default(0) // Giờ chuẩn theo công ty

  // GIỜ LÀM THÊM (phục vụ tính lương OT)
  overtimeWeekdayHours Float @default(0) // Làm thêm ngày thường
  overtimeWeekendHours Float @default(0) // Làm thêm ngày nghỉ
  overtimeHolidayHours Float @default(0) // Làm thêm ngày lễ

  //
  totalPaidHours Float @default(0) // Tổng giờ làm thực tế tính công chuẩn + giờ làm thêm

  // NGHỈ PHÉP
  paidLeaveDays         Float @default(0) // Nghỉ có lương
  unpaidLeaveDays       Float @default(0) // Nghỉ không lương
  unexcusedLeaveDays    Float @default(0) // Nghỉ không lý do
  // detail
  annualLeaveDays       Float @default(0) // Nghỉ phép năm
  remoteApplicationDays Float @default(0) // Remote days

  // NGÀY ĐẶC BIỆT
  holidayDays      Float @default(0) // Số ngày nghỉ lễ
  businessTripDays Float @default(0) // Công tác

  // TIỀN PHẠT
  lateMinutes       Float? // Số phút đi muộn
  earlyLeaveMinutes Float? // Số phút về sớm
  missedChecks      Int    @default(0) // Số lần quên chấm công

  penaltyLateAmount        Int @default(0) // Phạt đi muộn
  penaltyEarlyLeaveAmount  Int @default(0) // Phạt về sớm
  penaltyUnexcusedAmount   Int @default(0) // Phạt nghỉ không lý do
  penaltyMissedCheckAmount Int @default(0) // Phạt quên chấm công
  totalPenaltyAmount       Int @default(0) // Tổng phạt

  // === Nghỉ phép - use for view ===
  leaveDaysStart Float @default(0) // Số phép đầu kỳ
  leaveDaysUsed  Float @default(0) // Số phép đã dùng trong kỳ
  leaveDaysEnd   Float @default(0) // Số phép cuối kỳ

  isLocked Boolean @default(false)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, year, month])
  @@map("monthly_attendance_summary")
}

enum AttendanceStatus {
  PRESENT
  PARTIAL
  ABSENT
  ON_LEAVE
  LATE
  EARLY_LEAVE
  HALF_DAY
}

// ===== PAYROLL =====
model PayrollSummary {
  id String @id @default(cuid())

  // Period Information
  month Int
  year  Int
  // title String // Tên bảng lương

  // Status
  status            PayrollStatusEnum @default(DRAFT) // DRAFT => PROCESSING(kế toán gửi yc phê duyệt tự chuyển sang processing) => APPROVED,DISAPPROVED => PAID
  comments          String?
  disapprovedReason String? // Lý do không duyệt
  approvedBy        String? // Người duyệt
  approvedByUser    User?             @relation(fields: [approvedBy], references: [id]) // Người duyệt
  approvedAt        DateTime? // Thời gian duyệt
  // General
  totalEmployees    Int               @default(0)

  // Salary
  totalGrossSalary Float @default(0) // Tổng lương (gross, trước khấu trừ)
  totalNetSalary   Float @default(0) // Thực lĩnh nhân viên nhận (net)

  // Trade Union
  totalCompanyTradeUnionFee Float @default(0) // Kinh phí công đoàn (công ty đóng)

  // Company Contributions (do công ty trả thêm)
  totalCompanySocialInsurance Float @default(0) // BHXH Công ty (17.5%)
  totalCompanyHealthInsurance Float @default(0) // BHYT Công ty (3%)
  totalCompanyUnempInsurance  Float @default(0) // BHTN Công ty (1%)
  totalCompanyContributions   Float @default(0) // Tổng cộng công ty đóng (BHXH+BHYT+BHTN+KPCĐ)

  // Employee Contributions (trích từ lương nhân viên)
  totalEmployeeSocialInsurance Float @default(0) // BHXH Nhân viên (8%)
  totalEmployeeHealthInsurance Float @default(0) // BHYT Nhân viên (1.5%)
  totalEmployeeUnempInsurance  Float @default(0) // BHTN Nhân viên (1%)
  totalEmployeeContributions   Float @default(0) // Tổng cộng nhân viên trích

  // Deductions
  totalPersonalIncomeTax Float @default(0) // Thuế TNCN
  totalSalaryAdvance     Float @default(0) // Tạm ứng
  totalDeductions        Float @default(0) // Tổng trừ (Employee contrib + Tax + Advance)

  // Company Expenses (chi phí thực tế công ty bỏ ra)
  totalCompanyExpenses Float @default(0)
  // = GrossSalary + CompanyContributions + TradeUnionFee

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  PayrollEmployee PayrollEmployee[]

  @@unique([month, year])
  @@map("payroll_summary")
}

model PayrollEmployee {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id])

  month Int
  year  Int

  // Basic Information (A-F)
  // stt           Int // STT - Số thứ tự
  employeeCode  String // PERSONNEL_CODE - Mã nhân sự
  fullName      String // PERSONNEL_NAME - Họ tên
  jobTitle      String? // JOB_TITLE - Chức vụ
  contractType  String // CONTRACT_TYPE - Loại hợp đồng
  contractTitle String? // CONTRACT_TITLE - Tên hợp đồng

  // Salary Base (G-J)
  basicSalary         Float // LUONG_DONG_BH - Lương cơ bản - Lấy từ số liệu tháng trước, kế toán có thể sửa
  standardWorkingDays Float // NUMBER_WORKDAY - Số công chuẩn
  salaryTypeNet       Float // SALARY_TYPE_NET - Thu nhập theo lương - Lấy từ số liệu tháng trước, kế toán có thể sửa
  salaryActualNet     Float // TN_TL - Thu nhập theo lương thực

  // Attendance (K)
  actualWorkingDays Float // CAL_WORKDAY - Ngày công thực tế
  // leaveDays         Float @default(0) // LEAVE_DAYS - Số ngày nghỉ phép

  // Allowances (L-R)
  allowanceTransport       Float @default(0) // SALARY_ALLOW_6 - Phụ cấp xăng xe - Lấy từ số liệu tháng trước, kế toán có thể sửa
  allowanceTransportActual Float @default(0) // PC_XX - Phụ cấp xăng xe thực
  allowanceDegree          Float @default(0) // SALARY_ALLOW_8 - Phụ cấp bằng cấp - lấy từ tháng trước, có thể sửa
  allowanceLunch           Float @default(0) // SALARY_ALLOW_1 - Phụ cấp ăn trưa
  allowanceLunchActual     Float @default(0) // PC_AT - Phụ cấp ăn trưa thực - lấy từ tháng trước, có thể sửa
  allowancePhone           Float @default(0) // PC_DT - Phụ cấp điện thoại
  salaryActual             Float @default(0) // SALARY_TT - Lương thực tế - chua bao gồm phụ cấp TN_TL * (CAL_WORKDAY / NUMBER_WORKDAY)

  // Overtime (S-X)
  overtimeRegularHours  Float @default(0) // LT_NT - Tổng giờ làm thêm ngày thường
  overtimeRegularAmount Float @default(0) // LUONG_LT_NT - Tiền tăng ca ngày thường
  overtimeWeekendHours  Float @default(0) // LTNN - Tổng giờ làm thêm ngày nghỉ
  overtimeWeekendAmount Float @default(0) // LUONG_LT_NN - Tiền tăng ca ngày nghỉ
  overtimeHolidayHours  Float @default(0) // LT_NL - Tổng giờ làm thêm ngày lễ
  overtimeHolidayAmount Float @default(0) // LUONG_LT_NL - Tiền tăng ca ngày lễ

  // Bonuses (Y-AA)
  bonus        Float @default(0) // BONUS - Bonus - Tự nhập
  holidayBonus Float @default(0) // THUONG_LE - Thưởng lễ - Tự nhập
  totalSalary  Float @default(0) // TONG_LUONG - Tổng lương : SALARY_TT+PC_XX+PC_AT+SALARY_ALLOW_8+PC_DT+LUONG_LT_NT+LUONG_LT_NN+LUONG_LT_NL+BONUS+THUONG_LE

  // Company Contributions (AB-AF)
  unionFee            Float @default(0) // KPCD - Kinh phí công đoàn: tự nhập
  socialInsCompany    Float @default(0) // BHXH_CTY - Trích BHXH Công ty (17,5%)=LUONG_DONG_BH*0.175
  healthInsCompany    Float @default(0) // BHYT_CTY - Trích BHYT Công ty (3%)
  unemployInsCompany  Float @default(0) // BHTN_CTY - Trích BHTN Công ty (1%)
  totalCompanyContrib Float @default(0) // CONG_CTY - Cộng trích Công ty: KPCD+BHXH_CTY+BHYT_CTY+BHTN_CTY

  // Employee Deductions (AG-AJ)
  socialInsEmployee   Float @default(0) // BHXH_NV - Trích BHXH Nhân viên (8%)=LUONG_DONG_BH*0.08
  healthInsEmployee   Float @default(0) // BHYT_NV - Trích BHYT Nhân viên (1,5%)
  unemployInsEmployee Float @default(0) // BHTN_NV - Trích BHTN Nhân viên (1%)
  totalEmployeeDeduct Float @default(0) // CONG_NV - Cộng trích Nhân viên=BHXH_NV+BHYT_NV+BHTN_NV

  // Taxes and Other Deductions (AK-AM)
  personalIncomeTax Float @default(0) // THUE_TNCN - Thuế TNCN : tự nhập
  advance           Float @default(0) // TAM_UNG - Tạm ứng - Tự nhập
  totalDeductions   Float @default(0) // TONG_TRU - Tổng trừ=CONG_NV+THUE_TNCN+TAM_UNG

  // Net Pay (AN)
  netPay Float @default(0) // THUC_LINH - Thực lĩnh=TONG_LUONG-CONG_NV-THUE_TNCN-TAM_UNG

  // Payment Methods (AO-AR)
  paymentBankAccount Float @default(0) // TT_TK - Thanh toán tài khoản công ty: tự nhập
  paymentCash        Float @default(0) // TT_TM - Thanh toán tài khoản tiền mặt: tự nhập
  paymentOtBonus     Float @default(0) // TT_OT_THUONG - Thanh toán OT, Thưởng=THUC_LINH-TT_TK-TT_TM
  paymentOtBonusCash Float @default(0) // TT_OT_THUONG_TM - Thanh toán OT, Thưởng tiền mặt=THUC_LINH-TT_TK-TT_TM-TT_OT_THUONG

  // Bank Information (AS-AT)
  bankAccount String? // BANK_ACCOUNT - Số tài khoản ngân hàng
  bankName    String? // BANK_NAME - Tên ngân hàng

  // Contract type ratio for calculation
  contractTypeRatio Float @default(1.0) // Tỉ lệ theo loại hợp đồng

  // Status and Processing
  status                    PayrollStatusEnum @default(DRAFT) // DRAFT => EMPLOYEE_APPROVED => DISAPPROVED, APPROVED => PAYMENT_PROCESSING => PAID
  employeeDisapprovedReason String? // Lý do trạng thái (nếu có)
  disapprovedReason         String? // Lý do trạng thái (nếu có)
  calculatedAt              DateTime?
  approvedAt                DateTime?
  processedAt               DateTime?
  processedBy               String?
  paidAt                    DateTime?
  paidBy                    String?

  // Split line handling (for contract type changes mid-month)
  isSplitRecord  Boolean           @default(false)
  parentRecordId String?
  parentRecord   PayrollEmployee?  @relation("PayrollEmployeeSplit", fields: [parentRecordId], references: [id], onDelete: Cascade)
  splitRecords   PayrollEmployee[] @relation("PayrollEmployeeSplit")

  notes String?

  changeFields String[] @default([]) // Fields that have been changed value by manual edit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  PayrollSummary   PayrollSummary? @relation(fields: [payrollSummaryId], references: [id])
  payrollSummaryId String?

  @@unique([employeeId, month, year, isSplitRecord, contractType])
  @@map("payroll_employee")
}

enum PayrollStatusEnum {
  DRAFT
  PROCESSING
  EMPLOYEE_APPROVED
  EMPLOYEE_DISAPPROVED
  DISAPPROVED
  APPROVED
  PAYMENT_PROCESSING
  PAID
  CANCELLED
}

// ===== ACCOUNTING MODULE =====
model Voucher {
  id          String      @id @default(cuid())
  code        String      @unique // Auto generate: PT_xxx / PC_xxx
  voucherType VoucherType // RECEIPT / PAYMENT

  issueDate   DateTime // Ngày thu/chi
  postingDate DateTime // Ngày hạch toán (có thể bỏ nếu ko cần)

  content String // Nội dung thu/chi
  // contentCode String? // Mã nội dung thu/chi (gom nhóm)

  accountId String? // Tài khoản thu/chi
  account   MoneyAccount? @relation(fields: [accountId], references: [id])

  partnerCode String? // đối tượng thu/chi (có thể bỏ nếu ko cần): Category with type   RECEIPT_PARTNER_VOUCHER / PAYMENT_PARTNER_VOUCHER

  payerReceiver String? // Người nộp/nhận tiền
  bankAccount   String? // Số tài khoản nộp/nhận
  bankCode      String? // Ngân hàng nộp/nhận: Category with type BANK

  // approverId String?
  // approver   User?   @relation("VoucherApprover", fields: [approverId], references: [id])

  note        String? // Ghi chú
  attachments String[] // Đính kèm files ids

  currency       String            @default("VND")
  exchangeRate   Decimal?          @db.Decimal(18, 6) // Nếu có ngoại tệ
  taxIncluded    Boolean           @default(false) // Có bao gồm thuế không
  totalAmount    Decimal           @db.Decimal(18, 2) // Tổng tiền
  details        VoucherDetail[]
  relatedObjects VoucherRelation[]

  status    VoucherStatusEnum @default(DRAFT)
  approvals VoucherApproval[] // Quy trình duyệt

  createdBy String?
  creator   User?   @relation("VoucherCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // SettlementFormVoucherPayment SettlementFormVoucherPayment[]
  // SettlementFormVoucherReceipt SettlementFormVoucherReceipt[]
  @@map("voucher")
}

model VoucherDetail {
  id        String  @id @default(cuid())
  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  description String // Diễn giải chi tiết lý do thu/chi
  quantity    Int     @default(1) // Số lượng
  amount      Decimal @db.Decimal(18, 2) // Số tiền
  // currency        String  @default("VND") // Đơn vị tiền //todo: remove, use same in Voucher

  expenseCategory String? // use Category EXPENSE_CATEGORY, REVENUE_CATEGORY
  expenseObject   String? // use Category EXPENSE_OBJECT, REVENUE_OBJECT

  employeeId String? //
  employee   EmployeeProfile? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  customerId String? // use for RECEIPT
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  supplierId String? // use for PAYMENT
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  taxRate     Decimal? @db.Decimal(5, 2) // % thuế (nếu có)
  taxAmount   Decimal? @db.Decimal(18, 2) // Tiền thuế
  totalAmount Decimal  @db.Decimal(18, 2) // Tổng cộng (amount + tax)

  @@map("voucher_detail")
}

// Liên kết chứng từ với các đối tượng liên quan (hóa đơn, dự án, quy trình...)
model Customer {
  id      String  @id @default(cuid())
  code    String  @unique // Mã KH
  name    String // Tên KH, công ty
  taxCode String? // MST (có hoặc không)
  email   String? // Email

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  VoucherDetail VoucherDetail[]
}

// verdor = supplier
model Supplier {
  id              String    @id @default(cuid())
  code            String    @unique // Mã NCC dạng text
  name            String // Tên NCC dạng text
  contractDate    DateTime? // Ngày ký HĐ
  contractEndDate DateTime? // Ngày kết thúc HĐ
  renewalDate     DateTime? // Ngày gia hạn mới
  newEndDate      DateTime? // Ngày kết thúc mới

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ==== Thông tin cơ bản ====
  companySize    Int? // Quy mô (số nhân sự)
  companyProfile String? // Profile / mô tả công ty
  website        String? // Website nếu có

  // ==== Đầu mối liên hệ ====
  contactName  String? // Tên người liên hệ
  contactTitle String? // Chức vụ
  contactPhone String?
  contactEmail String?

  // ==== Trạng thái ====
  status VendorStatus @default(ACTIVE) // Hoạt động / Không hoạt động

  // ==== Hợp đồng ====
  sourcingType SourcingType? // ODC / Fixed price / T&M

  // ==== Năng lực kỹ thuật ====
  domains    String? // Domain chính (CRM, Fintech, Healthcare...)
  techStacks String? // Tech stack trọng điểm (Java, Spring, React...)

  // ==== Nhân sự & ngoại ngữ ====
  englishLevel   sourcing_candidate_language_level_enum? // Trình độ tiếng Anh trung bình
  otherLanguages String? // Ngôn ngữ khác (JP, KR...)

  // ==== Rate ====
  offeredRate String? // Rate chào (USD/day hoặc USD/month)
  averageRate String? // Rate trung bình

  // ==== Audit ====

  // ==== Relations ====
  VoucherDetail   VoucherDetail[]
  employeeProfile EmployeeProfile[]

  sourcingCandidates sourcing_candidate[]
}

enum VendorStatus {
  ACTIVE
  INACTIVE
}

enum SourcingType {
  ODC
  FIXED_PRICE
  TIME_MATERIAL
}

model MoneyAccount {
  id          String  @id @default(cuid()) // Khóa chính
  code        String  @unique // Mã tài khoản (VD: 111, 112, 131...) Bank acc number
  name        String // Tên tài khoản (VD: Tiền mặt, Ngân hàng...) Bank acc name
  description String? // Mô tả chi tiết (VD: "TK chi phí", "TK thuế, BHXH")
  bank        String? // Tên ngân hàng (VD: "Kỹ Thương Việt Nam", "Tiền mặt")  Bank Name
  // other fields
  bankAddress String? // Bank address
  iban        String? // IBAN
  bic         String? // BIC
  swiftCode   String? // Bank’s Swift Code
  bankCode    String? // Bank’s Code
  branchCode  String? // Branch Code

  isActive  Boolean  @default(true) // Có được sử dụng không
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Liên kết với các voucher
  voucher Voucher[]

  @@map("money_accounts")
}

enum ProjectStatus {
  ON_GOING // On Going
  PROCESSING // remove later, use ON_GOING
  ON_HOLD // On Hold
  MAINTAIN // Maintain
  PENDING // Pending
  CLOSED // Closed
  BIDDING // Bidding
}

model Project {
  id     String        @id @default(cuid())
  code   String        @unique // Mã dự án
  name   String // Tên dự án
  status ProjectStatus @default(ON_GOING) // Tình trạng dạng dropdown

  jiraKey        String?              @map("jira_key") // Mã dự án Jira (project key)
  jiraId         String?              @map("jira_id") // ID của Jira project để liên kết
  // Category relation
  jiraCategoryId String?              @map("jira_category_id")
  jiraCategory   JiraProjectCategory? @relation(fields: [jiraCategoryId], references: [id])

  clientName   String?   @map("client_name") // Tên khách hàng
  contactPoint String?   @map("contact_point") // Tên người liên hệ
  // Thời gian
  startDate    DateTime? @map("start_date") // Thời gian bắt đầu
  endDate      DateTime? @map("end_date") // Thời gian kết thúc
  notes        String?   @db.Text // Ghi chú

  followerId String?          @map("follower_id") // Người theo dõi dự án
  follower   EmployeeProfile? @relation("FollowerProject", fields: [followerId], references: [id])

  clientFollowerId String?          @map("client_follower_id") // Người theo dõi dự án
  clientFollower   EmployeeProfile? @relation("ClientFollowerProject", fields: [clientFollowerId], references: [id])

  isEvaluationRequired Boolean @default(true) @map("is_evaluation_required") // Toggle bật/tắt hệ thống

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  VoucherDetail VoucherDetail[]

  projectMembers ProjectMember[]

  candidateProjects CandidateProject[]

  // NEW: Relations cho hệ thống đánh giá
  evaluationSummaries ProjectEvaluationSummary[] // Tổng hợp điểm theo kỳ
  evaluations         ProjectEvaluation[] // Tổng hợp điểm theo kỳ follower
}

// ============================================
// MODEL MỚI: PROJECT - STAFF RELATIONSHIP
// ============================================

model ProjectMember {
  id String @id @default(cuid())

  // Foreign keys
  projectId  String @map("project_id")
  employeeId String // Link tới EmployeeProfile

  // Thông tin vai trò và thời gian
  position  String? // Vai trò trong dự án category with type POSITION
  startDate DateTime  @map("start_date") // Ngày bắt đầu tham gia
  endDate   DateTime? @map("end_date") // Ngày kết thúc (null nếu còn làm)
  notes     String?   @db.Text // Ghi chú

  followerId String?          @map("follower_id") // Người theo dõi dự án
  follower   EmployeeProfile? @relation("EmployeeProjectMemberFollower", fields: [followerId], references: [id])

  attachments         String[] // Đính kèm files ids
  defaultWorkingHours Float?   @map("default_working_hours") // Số giờ làm việc mặc định hàng ngày 2.5h cho PM

  // Metadata
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deleted   Boolean  @default(false)

  // Relations
  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee EmployeeProfile @relation("EmployeeProjectMembership", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId, position, startDate]) // Một người có thể có nhiều vai trò khác nhau hoặc tham gia lại
  @@index([projectId])
  @@index([employeeId])
  @@index([startDate])
  @@map("project_members")
}

model VoucherRelation {
  id        String  @id @default(cuid())
  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  relatedType RelatedObjectType // INVOICE, PROJECT, PROCESS...
  relatedId   String // ID thực tế

  @@unique([voucherId, relatedType, relatedId])
  @@map("voucher_relations")
}

model VoucherApproval {
  id         String  @id @default(cuid())
  voucherId  String
  voucher    Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  approverId String
  approver   User    @relation(fields: [approverId], references: [id], onDelete: Cascade)

  status   ApprovalStatus @default(PENDING)
  comments String?
  index    Int            @default(0) // Thứ tự duyệt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("voucher_approvals")
}

enum VoucherType {
  RECEIPT // Phiếu thu
  PAYMENT // Phiếu chi
}

enum VoucherStatusEnum {
