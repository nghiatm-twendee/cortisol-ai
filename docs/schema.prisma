// ======================================
// ===== ENTITY AUDIT LOG SYSTEM ========
// ======================================
// Enum cho loại entity được audit
enum EntityAuditTargetType {
  CANDIDATE // refactor from sourcing_candidate
  DEAL // refactor from sales_deal
  APPLICATION // refactor from time_application
  PROJECT
  // thêm mới chỉ cần add enum value
  CRM_COMPANY
  CRM_LEAD
  CRM_DEAL
  CRM_FOLLOW_UP
}

model EntityAuditLog {
  id String @id @default(cuid())

  // === Target: đối tượng được audit ===
  targetType EntityAuditTargetType // CANDIDATE, DEAL, MEMBER, ...
  targetId   String // ID của entity đó

  // === Sub-entity (optional) ===
  // Ví dụ: deal thay đổi submission → relatedType = SUBMISSION, relatedId = <submissionId>
  // Ví dụ: candidate thay đổi skill → relatedType = SKILL, relatedId = <skillId>
  relatedType String? // string vì sub-entity rất nhiều, không cần enum
  relatedId   String?

  // === Action ===
  // Value là i18n key, ví dụ: "candidate.action.create"
  action  String
  context String? // mô tả ngắn: "Moved deal to SCANNING", "Removed submission X"

  // === Dữ liệu thay đổi ===
  // Format: { field: "status", oldValue: "NEW", newValue: "SCANNING" }
  // Hoặc array nếu multi-field: [{ field, oldValue, newValue }, ...]
  changes Json?

  // === Người thực hiện ===
  performedBy String
  performer   User   @relation("EntityAuditor", fields: [performedBy], references: [id])

  // === Network info ===
  ipAddress String?
  userAgent String? @db.Text

  // === Metadata ===
  createdAt DateTime @default(now())

  // === Indexes ===
  // Query chính: "lấy history của entity X" → cần (targetType, targetId, createdAt)
  @@index([targetType, targetId, createdAt(sort: Desc)])
  // Query: "ai đã làm gì" → cần (performedBy, createdAt)
  @@index([performedBy, createdAt])
  // Query: "filter by action type"
  @@index([action])
  // Sub-entity lookup
  @@index([relatedType, relatedId])
  @@map("entity_audit_logs")
}

// =====================================================
// RECRUITMENT DEAL MANAGEMENT SYSTEM - SCHEMA ADDITION
// =====================================================

// Trạng thái Deal
enum DealStatus {
  NEW // Mới tạo (default)
  SCANNING // Đang tìm CV
  QUALIFYING // Đang đánh giá
  PENDING // Đang chờ
  DROPPED // Hủy bỏ
  DONE // Hoàn thành
}

// Loại hình làm việc
enum WorkingType {
  INDIVIDUAL // Cá nhân
  COLLABORATE_EXISTING // Phối hợp với team có sẵn
  VN_TEAM // Team VN
}

// Mức độ tiếng Anh
enum EnglishLevel {
  NONE // Không
  INTERMEDIATE // Trung bình
  FLUENT // Thành thạo
}

// Độ ưu tiên (auto từ Potentiality, có thể modify sau)
enum DealPriority {
  HIGH // Từ 90%
  MEDIUM // Từ 50%
  LOW // Từ 30%
}

// Level vị trí
enum PositionLevel {
  JUNIOR // Junior
  MIDDLE // Middle
  SENIOR // Senior
  TECH_LEAD // Tech Lead
}

// Trạng thái Candidate trong Deal
enum CandidateInDealStatus {
  CV_SCREENING // Lọc CV
  APPLICATION_PASSED // Ứng tuyển đạt
  APPLICATION_REJECTED // Ứng tuyển loại
  BLACKLIST // Blacklist
  PENDING_INTERVIEW // Chờ phỏng vấn
  INTERVIEW_FAILED // Phỏng vấn không đạt
  INTERVIEW_PASSED // Phỏng vấn đạt
  INTERVIEW_DECLINED // Từ chối phỏng vấn
  PENDING_INTERVIEW_2 // Chờ phỏng vấn lần 2
  INTERVIEW_2_PASSED // Phỏng vấn đạt lần 2
  INTERVIEW_2_FAILED // Phỏng vấn trượt lần 2
  OFFER_ACCEPTED // Đồng ý Offer
  OFFER_REJECTED // Từ chối Offer
  PENDING_ONBOARD // Chờ nhận việc
  ONBOARD_ACCEPTED // Đồng ý nhận việc
  ONBOARD_REJECTED // Từ chối nhận việc
  REQUEST_CANCELLED // Hủy request
  CONSIDERING // Cân nhắc
}

// ===== MAIN TABLES =====

// Bảng Deal (Yêu cầu nhân sự)
model RecruitmentDeal {
  id String @id @default(cuid())

  dealName String? // Tên deal

  // CRM link — chỉ set khi CrmDeal.type = ODC
  crmDealId String?  @unique
  crmDeal   CrmDeal? @relation("CrmDealRecruitment", fields: [crmDealId], references: [id])

  // Thông tin khách hàng
  clientName String // Tên khách hàng
  country    String // Quốc gia (dropdown) Category with type COUNTRY

  // Thông tin công việc
  workingTime       String? // Thời gian làm việc (textbox)
  workingType       WorkingType // Loại hình: Individual/Collaborate/VN Team
  overlapsedTime    String? // Thời gian overlap (textbox)
  hardCommunication Boolean      @default(false) // Khó giao tiếp hay không
  englishLevel      EnglishLevel // Mức độ tiếng Anh

  // Thông tin deal
  description  String?       @db.Text // Mô tả
  potentiality Int? // Độ tiềm năng: 90%, 50%, 30%
  priority     DealPriority? // Độ ưu tiên (tự động gán theo Potentiality: 90% -> High, 50% -> Medium, 30% -> Low, field này có thể được modify sau nhưng tại thời điểm tạo deal sẽ là auto filled)
  // positions relation bên dưới

  interviewProcess String? @db.Text // Quy trình phỏng vấn (textbox)

  // Thông tin bổ sung
  note String? @db.Text // Ghi chú (textbox)

  // Trạng thái
  status DealStatus @default(NEW) // Auto set NEW khi tạo

  attachments String[] // Đính kèm files ids

  // Người tạo (Sales/BD)
  createdById String
  createdBy   User   @relation("DealCreator", fields: [createdById], references: [id])

  followerId String? @map("follower_id") // Người theo dõi dự án ứng viên
  follower   User?   @relation("UserRecruitmentDealFollower", fields: [followerId], references: [id])

  // Metadata
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderIndex Int? @default(0) // Dùng để sắp xếp thủ công trong pipeline , tăng mỗi 1000 để dễ dàng chèn giữa các deal

  // Relations
  positions DealPosition[]

  candidateSubmissions DealCandidateSubmission[] // CV được submit vào deal
  histories            DealHistory[] // Lịch sử comment/thay đổi
  auditLogs            DealAuditLog[] // Audit log cho mọi thay đổi

  @@index([status, orderIndex]) // Query theo pipeline (status) và sắp xếp theo orderIndex
  @@index([createdById])
  @@index([createdAt])
  @@index([country])
  @@index([priority])
  @@index([potentiality])
  @@map("recruitment_deals")
}

// Format: [{ position: "Backend Dev", maxGrossRate: 30000000 }, ...]
// maxGrossRate: VNĐ (format số)

model DealPosition {
  id String @id @default(cuid())

  dealId String
  deal   RecruitmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  position     String
  level        PositionLevel? // Level: Junior, Middle, Senior, Tech Lead
  quantity     Int            @default(1) // Số lượng vị trí cần tuyển
  maxGrossRate Decimal?       @db.Decimal(15, 2)

  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([dealId])
  @@map("deal_positions")
}

// Bảng Submit Candidate vào Deal
model DealCandidateSubmission {
  id String @id @default(cuid())

  // Deal
  dealId String
  deal   RecruitmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // Candidate hoặc Employee (chỉ có 1 trong 2)
  candidateId String?
  candidate   sourcing_candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  employeeId String?
  employee   EmployeeProfile? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Level apply cho candidate/employee này (chọn khi submit)
  level PositionLevel? // Junior, Middle, Senior, Tech Lead

  // CV đính kèm (có thể khác với CV gốc của candidate)
  attachments String[] // Đính kèm files ids

  // Trạng thái của candidate/employee trong deal này
  status CandidateInDealStatus @default(CV_SCREENING)
  // Thông tin bổ sung
  note   String?

  // Người submit (HR - follower của candidate)
  submittedBy String
  submitter   User   @relation("CandidateSubmitter", fields: [submittedBy], references: [id])

  // Metadata - lưu thời điểm để phục vụ thống kê
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  statusLogs SubmissionStatusLog[] // Lịch sử thay đổi trạng thái

  @@unique([dealId, candidateId]) // Một candidate chỉ submit 1 lần vào 1 deal
  @@unique([dealId, employeeId]) // Một employee chỉ submit 1 lần vào 1 deal
  @@index([dealId])
  @@index([candidateId])
  @@index([employeeId])
  @@index([submittedBy])
  @@index([status])
  @@index([submittedAt]) // Để query thống kê theo thời gian
  @@map("deal_candidate_submissions")
}

model SubmissionStatusLog {
  id String @id @default(cuid())

  submissionId String
  submission   DealCandidateSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  fromStatus CandidateInDealStatus
  toStatus   CandidateInDealStatus
  reason     String                @db.Text

  performedBy String
  performer   User   @relation("StatusLogPerformer", fields: [performedBy], references: [id])

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("submission_status_logs")
}

// Bảng Lịch sử Deal (Comment/Timeline)
// Ghi lại từng lần khách hàng phản hồi, tracking quá trình
model DealHistory {
  id String @id @default(cuid())

  dealId String
  deal   RecruitmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // Nội dung comment/history
  content String @db.Text

  // Loại history (optional, để phân biệt và filter)
  type String? @default("comment") // 'comment', 'status_change', 'submission', 'client_feedback', etc.

  // Người tạo comment
  createdById String
  createdBy   User   @relation("DealHistoryCreator", fields: [createdById], references: [id])

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Cho phép edit comment (như Telegram)
  isEdited  Boolean  @default(false) // Đánh dấu comment đã được edit

  // Soft delete cho comment
  deleted   Boolean   @default(false)
  deletedAt DateTime?

  @@index([dealId])
  @@index([createdById])
  @@index([createdAt])
  @@index([type])
  @@index([deleted]) // Để filter out deleted comments
  @@map("deal_histories")
}

// Bảng Audit Log cho Deal
// Lưu lại mọi thay đổi quan trọng của deal
enum DealAuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ADD_SUBMISSION
  UPDATE_SUBMISSION_STATUS
  REMOVE_SUBMISSION
}

model DealAuditLog {
  id String @id @default(cuid())

  dealId String
  deal   RecruitmentDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // Thông tin audit
  action       DealAuditAction // 'CREATE', 'UPDATE', 'DELETE', 'STATUS_CHANGE', ADD_SUBMISSION, UPDATE_SUBMISSION_STATUS, REMOVE_SUBMISSION, etc.
  entity       String          @default("deal") // 'deal', 'submission', etc.
  submissionId String? // Nếu action liên quan đến submission thì có ID này
  context      String? // Mô tả ngắn gọn về action: remove submission X from deal Y, etc.

  // Dữ liệu thay đổi (JSON)
  // Format: { field: "status", oldValue: "NEW", newValue: "SCANNING" }
  changes Json?

  // Người thực hiện
  performedBy String
  performer   User   @relation("DealAuditor", fields: [performedBy], references: [id])

  // IP và thông tin bổ sung
  ipAddress String?
  userAgent String? @db.Text

  // Metadata
  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([performedBy])
  @@index([action])
  @@index([createdAt])
  @@map("deal_audit_logs")
}

// ===== CORE COMPETENCY ASSESSMENT SYSTEM =====

// Bảng loại năng lực (5 tiêu chí cố định)
model CompetencyType {
  id String @id @default(cuid())

  code        String  @unique // VD: "LANGUAGE", "COMMUNICATION", "LEADERSHIP", "PROFESSIONALISM", "TECHNICAL"
  name        String // VD: "Năng lực Ngoại ngữ (Language Competency)"
  nameVi      String?
  description String? @db.Text
  orderIndex  Int     @default(0) // Thứ tự hiển thị trong biểu đồ
  weight      Float   @default(1.0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  levels            CompetencyLevel[]
  assessmentDetails CompetencyAssessmentDetail[]

  @@map("competency_types")
}

// Bảng level của từng năng lực
model CompetencyLevel {
  id String @id @default(cuid())

  competencyTypeId String
  competencyType   CompetencyType @relation(fields: [competencyTypeId], references: [id], onDelete: Cascade)

  code        String // VD: "L1", "L2", "C0", "C1", "P-L1"
  name        String // VD: "Level 1", "Beginner"
  nameVi      String?
  description String? @db.Text

  // Giá trị số để tính toán biểu đồ radar (1-5 hoặc 0-4)
  numericValue Int @default(0) // VD: L1=1, L2=2, L3=3, L4=4

  orderIndex Int     @default(0) // Thứ tự hiển thị
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assessmentDetails CompetencyAssessmentDetail[]

  @@unique([competencyTypeId, code])
  @@index([competencyTypeId])
  @@index([numericValue])
  @@map("competency_levels")
}

// Bảng kỳ đánh giá năng lực
model CompetencyAssessmentPeriod {
  id String @id @default(cuid())

  year  Int // Năm đánh giá
  month Int // Tháng đánh giá (1-12)

  name        String? // VD: "Đánh giá năng lực 01/2026"
  description String? @db.Text

  startDate DateTime // Ngày bắt đầu kỳ
  endDate   DateTime? // Ngày kết thúc kỳ

  status AssessmentPeriodStatus @default(OPEN) // OPEN, CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assessments CompetencyAssessment[]

  @@unique([year, month])
  @@index([year, month])
  @@index([status])
  @@map("competency_assessment_periods")
}

enum AssessmentPeriodStatus {
  OPEN // Đang mở
  CLOSED // Đã đóng
}

// Bảng đánh giá năng lực của nhân sự
model CompetencyAssessment {
  id String @id @default(cuid())

  // Nhân sự được đánh giá
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Kỳ đánh giá
  periodId String
  period   CompetencyAssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  // Loại đánh giá
  assessmentType AssessmentType @default(MANAGER) // SELF, MANAGER

  // Người đánh giá (DM/BOD)
  assessorId String? // Null nếu là tự đánh giá
  assessor   User?   @relation("CompetencyAssessor", fields: [assessorId], references: [id])
  avgScore   Float?  @map("avg_score") // Điểm trung bình toàn bộ năng lực theo trọng số

  // Ghi chú chung cho bản đánh giá
  note String? @db.Text

  // Trạng thái
  status AssessmentStatus @default(DRAFT)

  // Thời gian
  submittedAt DateTime? // Thời điểm submit
  approvedAt  DateTime? // Thời điểm phê duyệt
  approvedBy  String? // User ID người phê duyệt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  details CompetencyAssessmentDetail[]

  @@unique([employeeId, periodId, assessmentType]) // Mỗi nhân sự, mỗi kỳ, mỗi loại chỉ có 1 bản đánh giá
  @@index([employeeId])
  @@index([periodId])
  @@index([assessorId])
  @@index([status])
  @@index([assessmentType])
  @@map("competency_assessments")
}

enum AssessmentType {
  SELF // Tự đánh giá
  MANAGER // Đánh giá bởi quản lý (DM/BOD)
}

enum AssessmentStatus {
  DRAFT // Nháp
  SUBMITTED // Đã nộp
  APPROVED // Đã phê duyệt
  REJECTED // Bị từ chối
}

// Bảng chi tiết đánh giá từng năng lực
model CompetencyAssessmentDetail {
  id String @id @default(cuid())

  assessmentId String
  assessment   CompetencyAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  competencyTypeId String
  competencyType   CompetencyType @relation(fields: [competencyTypeId], references: [id])

  // Level đánh giá
  levelId String
  level   CompetencyLevel @relation(fields: [levelId], references: [id])

  // Ghi chú cho năng lực này (optional)
  note String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assessmentId, competencyTypeId])
  @@index([assessmentId])
  @@index([competencyTypeId])
  @@index([levelId])
  @@map("competency_assessment_details")
}

// ===== SEED DATA EXAMPLE =====
// CompetencyType:
// 1. LANGUAGE - Năng lực Ngoại ngữ (orderIndex: 1)
//    Levels: UNDEFINED(0), L1(1), L2(2), L3(3), L4(4)
//
// 2. COMMUNICATION - Kỹ năng Giao tiếp (orderIndex: 2)
//    Levels: UNDEFINED(0), C0(1), C1(2), C2(3), C3(4)
//
// 3. LEADERSHIP - Kỹ năng Dẫn dắt (orderIndex: 3)
//    Levels: UNDEFINED(0), L1(1), L2(2), L3(3)
//
// 4. PROFESSIONALISM - Kỹ năng Chuyên nghiệp & Tuân thủ (orderIndex: 4)
//    Levels: UNDEFINED(0), P-L1(1), P-L2(2), P-L3(3)
//
// 5. TECHNICAL - Năng lực Chuyên môn kỹ thuật (orderIndex: 5)
//    Levels: FRESHER_JUNIOR(1), MIDDLE(2), SENIOR(3)

model HandoverAssignment {
  id        String  @id @default(cuid())
  processId String
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  // Assignment category: projectFollower, clientFollower, projectMemberFollower,
  // candidateProjectFollower, evaluationActionAssignee, timeApplicationApprover,
  // sourcingCandidateOwner, voucherApprover, processStepAssignee, manual
  category    String
  referenceId String?
  name        String
  detail      String?

  // Assignee info
  assigneeId       String
  assigneeUserId   String
  assigneeName     String
  assignedByUserId String

  // Status tracking
  status       String    @default("PENDING_CONFIRMATION")
  note         String?
  assigneeNote String?
  confirmedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([processId])
  @@index([assigneeUserId])
  @@index([status])
  @@map("handover_assignments")
}

// ==== SYSTEM CONFIGURATION FOR APPLICATION MANAGEMENT AND OTHER =====
model SystemConfig {
  id String @id @default(cuid())

  key         String  @unique // APPLICATION_OFFBOARDING_ENABLED, APPLICATION_LEAVE, APPLICATION_OVERTIME, APPLICATION_BUSINESS_TRIP,
  group       String? // APPLICATION, PAYROLL, HR
  description String?

  value Json // có thể boolean, number, string, object

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("system_configs")
}

// ============================================================
// CRM MODULE - Prisma Schema
// Relations: Company 0-n Lead, Lead 1-n Deal, Deal 0-1 RecruitmentDeal
// Tích hợp chung EntityAuditLog, Comment, Notification từ hệ thống hiện có
// ============================================================

// ================================================================
// CRM COMPANY
// ================================================================

model CrmCompany {
  id   String @id @default(cuid())
  name String // Check unique theo tên ở app-level

  // Multi-select: Fintech, AI, Ecommerce, Healthcare, etc.
  domains String[] // Lĩnh vực hoạt động Category with type DOMAIN: Category(type=DOMAIN).code

  description       String? @db.Text
  numberOfEmployees Int?
  website           String?
  email             String?
  phone             String?
  address           String?
  city              String?

  // FK mềm → Category(type=COUNTRY).code
  countryCode String?

  // Danh sách URL links
  links String?

  notes String? @db.Text

  createdById String
  createdBy   User   @relation("CrmCompanyCreator", fields: [createdById], references: [id])

  deleted   Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  leads CrmLead[]
  deals CrmDeal[]

  @@index([name])
  @@index([createdById])
  @@map("crm_companies")
}

// ================================================================
// CRM LEAD
// ================================================================

enum CrmLeadStage {
  NEW // Lead mới
  HOT_LEAD // Lead tiềm năng cao
  SQL // Sales Qualified Lead
  CLIENT // Đã là khách hàng
}

model CrmLead {
  id        String  @id @default(cuid())
  firstName String
  lastName  String?

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id])

  title String?

  // FK mềm → Category(type=COUNTRY).code — optional
  countryCode String?

  stage    CrmLeadStage @default(NEW)
  campaign String? // Mở rộng thành Lookup Campaign sau

  nextFollowUp DateTime?
  notes        String?   @db.Text

  createdById String
  createdBy   User   @relation("CrmLeadCreator", fields: [createdById], references: [id])

  // Referral: lead này được giới thiệu từ lead nào
  referredById String?
  referredBy   CrmLead?  @relation("LeadReferrals", fields: [referredById], references: [id])
  referrals    CrmLead[] @relation("LeadReferrals")

  deleted   Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contacts  CrmLeadContact[]
  dealLeads CrmDealLead[]

  @@index([stage])
  @@index([companyId])
  @@index([createdById])
  @@index([referredById])
  @@map("crm_leads")
}

// Flexible multi-contact: email, phone, zalo, telegram, whatsapp, slack, linkedin, ...
model CrmLeadContact {
  id     String  @id @default(cuid())
  leadId String
  lead   CrmLead @relation(fields: [leadId], references: [id])

  type  String // free-form: "email", "phone", "zalo", "telegram", "whatsapp", "slack", ...
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([type, value])
  @@map("crm_lead_contacts")
}

// ================================================================
// CRM DEAL
// ================================================================

enum CrmDealStatus {
  DISCOVERY // Discovery / Requirement Gathering (default)
  PREPARING_PROPOSAL // Preparing Proposal (Estimation, CV Sourcing)
  PROPOSAL_SENT // Proposal Sent
  WON // Won
  LOST // Lost
  ON_HOLD // On Hold
  PROJECT_STARTED // Project Started
  PROJECT_COMPLETED // Project Completed
  DROPPED // Dropped
}

enum CrmDealType {
  ODC // Outsourcing Development Center → tạo RecruitmentDeal
  FIXED_PRICE // Fixed Price
}

enum CrmDealTechnology {
  WEB2
  WEB3
}

enum CrmDealCurrency {
  USD
  VND
  JPY
  EUR
}

enum CrmContractStatus {
  DRAFT // Nháp
  SENT // Đã gửi
  SIGNED // Đã ký
  EXPIRED // Hết hạn
}

model CrmDeal {
  id   String @id @default(cuid())
  name String // Deal Name // @unique với deleted false check unique ở app-level vì xóa mềm

  // Company — auto fill từ Lead nếu có, hoặc override
  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id])

  status       CrmDealStatus      @default(DISCOVERY)
  type         CrmDealType
  potentiality Int? // Độ tiềm năng: 90%, 50%, 30%
  technology   CrmDealTechnology?

  // Multi-select: Fintech, AI, Ecommerce, Healthcare, Education, Gaming, Blockchain
  domains  String[] // Lĩnh vực hoạt động Category with type DOMAIN: Category(type=DOMAIN).code
  hashtags String[] // Free-form tags e.g. "Blockchain", "AI", "Web3"

  dealValue Float?
  currency  CrmDealCurrency @default(USD)

  description    String?            @db.Text
  contractLink   String?
  contractStatus CrmContractStatus?

  createdById String
  createdBy   User   @relation("CrmDealCreator", fields: [createdById], references: [id])

  deleted   Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  dealLeads CrmDealLead[]
  followers CrmDealFollower[]
  followUps CrmFollowUp[]
  comments  CrmComment[]

  // 0-1 với RecruitmentDeal — chỉ tạo khi type = ODC
  // FK thực nằm ở RecruitmentDeal.crmDealId (STEP 3)
  recruitmentDeal RecruitmentDeal? @relation("CrmDealRecruitment")

  orderIndex Int? @default(0) // Dùng để sắp xếp thủ công trong pipeline , tăng mỗi 1000 để dễ dàng chèn giữa các deal

  @@index([companyId])
  @@index([status, orderIndex]) // composite thay vì riêng lẻ
  // @@index([status])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
  @@map("crm_deals")
}

model CrmDealLead {
  dealId String
  deal   CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  leadId String
  lead   CrmLead @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())

  @@id([dealId, leadId])
  @@index([leadId])
  @@map("crm_deal_leads")
}

// ================================================================
// CRM DEAL FOLLOWERS
// Nhận thông báo khi Deal: tạo / cập nhật / đổi trạng thái
// ================================================================

model CrmDealFollower {
  id String @id @default(cuid())

  dealId String
  deal   CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("CrmDealFollower", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([dealId, userId])
  @@index([dealId])
  @@index([userId])
  @@map("crm_deal_followers")
}

// ================================================================
// CRM FOLLOW-UP
// Lịch họp / cuộc gọi gắn với Deal
// ================================================================
enum FollowUpStatus {
  TODO
  DONE
}

model CrmFollowUp {
  id String @id @default(cuid())

  title String

  dealId String
  deal   CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  startTime DateTime? // thời gian bắt đầu trên google calendar
  endTime   DateTime // dealine cho việc hoàn thành follow-up
  status    FollowUpStatus @default(TODO) // TODO, DONE

  description String? @db.Text // Nội dung buổi họp / cuộc gọi
  note        String? @db.Text // Ghi chú kết quả (có thể update sau khi họp xong)

  googleCalendarEventId String? // Google Calendar event ID for sync
  googleCalendarEndTime DateTime? // End time of the linked Google Calendar event (default: startTime + 1h)
  guestEmails           String[] // External guest emails for Google Calendar (e.g. lead email)

  createdById String
  createdBy   User   @relation("CrmFollowUpCreator", fields: [createdById], references: [id])

  deleted   Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Followers nhận:
  //   - Thông báo khi được gán vào follow-up
  //   - Nhắc tự động 10 phút trước startTime (job scheduler) hoặc khi tới hạn mà chưa hoàn thành
  followers CrmFollowUpFollower[]

  @@index([dealId])
  @@index([startTime])
  @@index([createdById])
  @@map("crm_follow_ups")
}

// ================================================================
// CRM FOLLOW-UP FOLLOWERS
// ================================================================

model CrmFollowUpFollower {
  id         String      @id @default(cuid())
  followUpId String
  followUp   CrmFollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("CrmFollowUpFollower", fields: [userId], references: [id])

  // Dùng cho scheduler: check field này để biết đã gửi nhắc chưa
  reminderSentAt DateTime?

  createdAt DateTime @default(now())

  @@unique([followUpId, userId])
  @@index([followUpId])
  @@index([userId])
  // Scheduler query: WHERE reminderSentAt IS NULL AND followUp.startTime <= now() + 10min
  @@index([reminderSentAt])
  @@map("crm_follow_up_followers")
}

// ================================================================
// CRM COMMENT
// Ghi chú nội bộ trên Deal
// ================================================================

model CrmComment {
  id String @id @default(cuid())

  dealId String
  deal   CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  content String @db.Text

  isEdited  Boolean   @default(false)
  deleted   Boolean   @default(false)
  deletedAt DateTime?

  createdById String
  createdBy   User   @relation("CrmCommentCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([createdById])
  @@index([deleted])
  @@map("crm_comments")
}

// ================================================================
// CRM NOTIFICATION
//
// Trigger cases:
//   Deal CRUD + status change → notify CrmDealFollowers + createdBy
//   FollowUp created          → notify CrmFollowUpFollowers
//   FollowUp reminder         → scheduler runs every minute, sends to
//                               CrmFollowUpFollower WHERE reminderSentAt IS NULL
//                               AND startTime/endTime BETWEEN now() AND now() + 10min
// ================================================================

enum CrmNotificationType {
  DEAL_CREATED // Deal mới được tạo
  DEAL_UPDATED // Deal được cập nhật thông tin
  DEAL_STATUS_CHANGED // Deal đổi trạng thái
  FOLLOW_UP_CREATED // Follow-up mới được tạo, gán follower
  FOLLOW_UP_UPDATED // Follow-up được cập nhật / note
  FOLLOW_UP_REMINDER // Nhắc lịch tự động 10 phút trước startTime
  COMMENT_CREATED // Comment mới trên deal
}

model CrmNotification {
  id String @id @default(cuid())

  type CrmNotificationType

  recipientId String
  recipient   User   @relation("CrmNotificationRecipient", fields: [recipientId], references: [id])

  title   String
  message String @db.Text

  // Deep-link tới entity: "CRM_DEAL" | "CRM_FOLLOW_UP" | "CRM_COMMENT"
  targetType String?
  targetId   String?

  // Dữ liệu bổ sung tuỳ loại noti
  // VD: { dealName, oldStatus, newStatus } | { followUpTitle, startTime }
  metadata Json?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("crm_notifications")
}
