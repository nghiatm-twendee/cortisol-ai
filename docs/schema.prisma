  isManual Boolean @default(false) @map("isManual") // true = tạo bằng tay để log work

  project  JiraProject   @relation(fields: [projectId], references: [id])
  worklogs JiraWorklog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JiraWorklog {
  id      String @id @map("id") @db.VarChar(50) // Jira worklog.id
