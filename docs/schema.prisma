// ===== Evaluation =====

// ============================================
// 1. PHẦN CẤU HÌNH HỆ THỐNG (Admin - Dương)
// ============================================

// Cấu hình hệ thống đánh giá
model EvaluationConfig {
  id String @id @default(cuid())

  // Cấu hình chung
  isActive               Boolean @default(true) @map("is_active") // Toggle bật/tắt hệ thống
  evaluationIntervalDays Int     @default(14) @map("evaluation_interval_days") // Bi-weekly = 14 days
  alertThresholdDays     Int     @default(3) @map("alert_threshold_days") // Số ngày chưa cập nhật thì alert

  // Phân loại dự án theo điểm trung bình
  normalMinScore Float @default(4.0) @map("normal_min_score") // >= 4.0: Bình thường
  issueMinScore  Float @default(2.5) @map("issue_min_score") // 2.5-3.9: Có issue
  // < 2.5: Critical

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("evaluation_configs")
}

// Bộ câu hỏi mẫu (chỉ có 1 bộ dùng chung, không phân loại)
model QuestionTemplate {
  id String @id @default(cuid())

  questionText String   @map("question_text") @db.Text // Nội dung câu hỏi
  weight       Float    @default(1.0) // Trọng số câu hỏi
  orderIndex   Int      @map("order_index") // Thứ tự hiển thị
  isActive     Boolean  @default(true) @map("is_active") // Câu hỏi có đang active không
  // Loại form đánh giá
  formType     FormType @default(TEAM) @map("form_type") // TEAM hoặc CLIENT

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relation: snapshot khi tạo kỳ đánh giá
  questionSnapshots EvaluationQuestion[]

  @@map("question_templates")
}

// ============================================
// 2. PHẦN DỮ LIỆU ĐÁNH GIÁ
// ============================================

// Bảng tổng hợp điểm chung cho TEAM + CLIENT trong cùng kỳ
model ProjectEvaluationSummary {
  id String @id @default(cuid())

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Thời gian kỳ đánh giá
  periodStartDate DateTime  @map("period_start_date")
  periodEndDate   DateTime? @map("period_end_date")

  // Điểm số từ các form
  overallScore Float? @map("overall_score") // Điểm TB chung (trung bình của team + client)

  // Trạng thái tổng quan
  overallStatus ProjectEvaluationStatus @default(NORMAL) @map("overall_status")

  // Ghi chú tổng hợp
  summaryNotes String? @map("summary_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  // evaluations ProjectEvaluation[]
  alerts EvaluationAlert[] // ✅ FIXED: Added relation

  @@unique([projectId, periodStartDate]) // Mỗi dự án, mỗi kỳ chỉ có 1 summary
  @@index([projectId])
  @@index([periodStartDate])
  @@index([periodEndDate]) // ✅ FIXED: Added index
  @@index([overallStatus])
  @@map("project_evaluation_summaries")
}

// Kỳ đánh giá của dự án - Mỗi row cho 1 loại form (TEAM hoặc CLIENT)
model ProjectEvaluation {
  id String @id @default(cuid())

  // Relation: Thuộc về summary nào (REQUIRED - không tồn tại độc lập)
  // summaryId String?                   @map("summary_id")
  // summary   ProjectEvaluationSummary? @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Loại form đánh giá
  formType FormType @map("form_type") // TEAM hoặc CLIENT

  // Thời gian kỳ đánh giá (đã chuyển sang summary)
  periodStartDate DateTime @default(now()) @map("period_start_date")

  evaluationDate DateTime? @map("evaluation_date") // Ngày thực tế đánh giá

  // Trạng thái đánh giá
  status EvaluationStatus @default(PENDING)

  // Điểm số tổng hợp
  averageScore Float? @map("average_score") // Điểm trung bình của form này

  // Trạng thái dự án dựa trên điểm
  projectStatus ProjectEvaluationStatus @default(NORMAL) @map("project_status")

  // Critical override
  hasCriticalIssue  Boolean @default(false) @map("has_critical_issue") // Radio button đánh dấu critical
  criticalIssueNote String? @map("critical_issue_note") @db.Text // Ghi chú vấn đề critical

  // Deadline
  hasDeadline         Boolean?  @default(false) @map("has_deadline")
  deadlineDate        DateTime? @map("deadline_date")
  deadlineDescription String?   @map("deadline_description") @db.Text // Deadline deliver cái gì

  // Người thực hiện đánh giá (follower tương ứng với formType)
  evaluatorId String?          @map("evaluator_id")
  evaluator   EmployeeProfile? @relation("Evaluator", fields: [evaluatorId], references: [id])

  // Ghi chú
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  questions            EvaluationQuestion[]
  participatingMembers EvaluationMember[] // Nhân sự tham gia được chọn
  // evaluationActionNotifications EvaluationActionNotification[] // Thông báo action gửi đến nhân sự
  alerts               EvaluationAlert[] // ✅ FIXED: Added relation

  actions EvaluationAction[] // Actions được tạo cho form này

  // ✅ FIXED: Corrected unique constraint and indexes
  @@unique([periodStartDate, projectId, formType]) //
  @@index([formType])
  @@index([status]) // ✅ FIXED: Added
  @@index([evaluatorId]) // ✅ FIXED: Added
  @@index([evaluationDate]) // ✅ FIXED: Added
  @@map("project_evaluations")
}

enum EvaluationStatus {
  PENDING // Chưa đánh giá
  IN_PROGRESS // Đang đánh giá
  COMPLETED // Đã hoàn thành
}

enum ProjectEvaluationStatus {
  NORMAL // >= normalMinScore
  ISSUE // >= issueMinScore và < normalMinScore
  CRITICAL // < issueMinScore hoặc hasCriticalIssue = true
}

// Snapshot câu hỏi tại thời điểm tạo kỳ đánh giá (bao gồm cả câu trả lời)
model EvaluationQuestion {
  id String @id @default(cuid())

  evaluationId String            @map("evaluation_id")
  evaluation   ProjectEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  templateId String?           @map("template_id") // Reference đến template gốc
  template   QuestionTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // Snapshot dữ liệu từ template
  questionText String @map("question_text") @db.Text
  weight       Float  @default(1.0)
  orderIndex   Int    @map("order_index")

  createdAt DateTime @default(now()) @map("created_at")

  // Câu trả lời (nullable - chưa trả lời thì null)
  score      Int?      @db.SmallInt // Thang điểm 1-5 (using SmallInt for efficiency)
  comment    String?   @db.Text // Ghi chú thêm
  answeredAt DateTime? @map("answered_at") // Thời điểm trả lời

  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([evaluationId])
  @@index([templateId]) // ✅ FIXED: Added
  @@map("evaluation_questions")
}

enum FormType {
  TEAM // Form cho team follower (sinh khi project có followerId)
  CLIENT // Form cho client follower (sinh khi project có clientFollowerId)
}

// Nhân sự/Candidate được chọn tham gia đánh giá
model EvaluationMember {
  id String @id @default(cuid())

  evaluationId String            @map("evaluation_id")
  evaluation   ProjectEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  // Có thể là nhân sự hoặc candidate
