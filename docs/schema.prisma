// ===== VIRTUALIZED FILE MANAGEMENT SYSTEM =====

// Virtual Drive - Each entity (User, Project, Department, etc.) has its own drive
model VirtualDrive {
  id          String  @id @default(cuid())
  name        String // Display name for the drive
  description String?

  // Entity association (polymorphic)
  entityId   String
  entityType String // User, Project, Department, LeaveRequest, etc.

  // Scope-based organization
  // scopeId String?
  // scope   Scope?  @relation(fields: [scopeId], references: [id])

  // Drive settings
  maxStorageSize BigInt? // Maximum storage in bytes (null = unlimited)
  isPublic       Boolean @default(false) // Whether the drive is publicly accessible
  isActive       Boolean @default(true)

  // Root folder reference
  rootFolderId String? @unique

  // Metadata
  createdBy String // User ID who created the drive

  // Relations
  rootFolder  Folder?           @relation("DriveRootFolder", fields: [rootFolderId], references: [id])
  folders     Folder[]          @relation("DriveAllFolders")
  files       File[]
  permissions DrivePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityType, entityId]) // One drive per entity
  @@map("virtual_drives")
}

// Virtual Folder - Hierarchical folder structure within drives
model Folder {
  id          String  @id @default(cuid())
  name        String
  description String?
  path        String // Full path from root (e.g., "/Documents/Projects/2024")

  // Hierarchy
  parentId String?
  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children Folder[] @relation("FolderHierarchy")

  // Drive association
  driveId String
  drive   VirtualDrive @relation("DriveAllFolders", fields: [driveId], references: [id], onDelete: Cascade)

  // Special folder types
  isSystemFolder Boolean @default(false) // System folders like "Avatar", "Documents", etc.
  folderType     String? // avatar, documents, attachments, shared, etc.

  // Permissions and settings
  isPublic Boolean @default(false)

  // Metadata
  createdBy String? // User ID who created the folder
  creator   User?   @relation("FolderCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  // Relations
  files       File[]
  permissions DrivePermission[]
  shareLinks  FileShareLink[]
  driveAsRoot VirtualDrive?     @relation("DriveRootFolder")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([driveId, path]) // Unique path within drive
  @@map("folders")
}

// File - Individual files within folders
model File {
  id       String @id @default(cuid())
  fileName String
  path     String // S3 key or local file path
  fileSize BigInt
  mimeType String

  // File organization
  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id])

  driveId String
  drive   VirtualDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)

  // File metadata
  category    String   @default("other") // avatar, document, attachment, etc.
  tags        String[] // Searchable tags
  description String?

  // File status and versioning
  status   String  @default("pending") // pending, uploaded, processing, ready, deleted
  version  Int     @default(1)
  isLatest Boolean @default(true)

  // Access control
  isPublic Boolean @default(false)

  // Entity association (for backward compatibility and quick access)
  entityId   String?
  entityType String?

  // Metadata
  uploadedBy String? // User ID who uploaded the file
  uploader   User?   @relation("FileUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)

  deleted Boolean @default(false)

  // File relationships
  parentFileId   String? // For file versions
  parentFile     File?            @relation("FileVersions", fields: [parentFileId], references: [id])
  versions       File[]           @relation("FileVersions")
  shareLinks     FileShareLink[]
  FileManagement FileManagement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("files")
}

// Drive Permissions - Control access to drives and folders
model DrivePermission {
  id String @id @default(cuid())

  // Target (what is being accessed)
  driveId String?
  drive   VirtualDrive? @relation(fields: [driveId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // Subject (who has access)
  userId String? // Specific user
  role   String? // Role-based access (HR, ADMIN, etc.)

  // Permission level
  permission String // read, write, admin, owner

  // Metadata
  grantedBy String // User ID who granted the permission

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drive_permissions")
}

// File Share Links - Temporary or permanent sharing links
model FileShareLink {
  id    String @id @default(cuid())
  token String @unique // Unique sharing token

  fileId String?
  file   File?   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // Share settings
  permission    String    @default("read") // read, write
  expiresAt     DateTime?
  maxDownloads  Int?
  downloadCount Int       @default(0)

  // Access control
  requiresPassword Boolean  @default(false)
  passwordHash     String?
  allowedEmails    String[] // Specific emails that can access

  // Metadata
  createdBy String // User ID who created the share

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("file_share_links")
}

