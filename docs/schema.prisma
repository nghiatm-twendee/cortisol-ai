// Process workflow

enum ProcessStatus {
  TODO
  PROCESSING
  COMPLETED
  CANCELLED
}

model Process {
  id          String        @id @default(cuid())
  name        String
  processType String // e.g., "Onboarding"
  status      ProcessStatus @default(TODO) // todo, processing, completed, failed
  description String?
  startTime   DateTime?
  endTime     DateTime?
  isHourly    Boolean       @default(false) // Giao việc theo giờ?
  attachments String[] // File đính kèm

  createAt  DateTime  @default(now())
  createdBy String?
  creator   User?     @relation("ProcessCreator", fields: [createdBy], references: [id])
  updatedAt DateTime? @updatedAt

  // Quan hệ
  responsibleUsers ProcessUser[] // Nhiều user chịu trách nhiệm

  // for each process type
  onboardData OnboardingProcess?
  // EmployeeTemp EmployeeTemp[]

  processData         Json? // store form data of any process dynamic part ( currently just store offboard form data for init)
  purchaseWorkflow    PurchaseWorkflow?
  offboardingWorkflow OffboardingWorkflow?

  changeSocialInsuranceWorkflow ChangeSocialInsuranceWorkflow?

  ProcessStep        ProcessStep[]
  WorkflowChecklist  WorkflowChecklist[]
  HandoverAssignment HandoverAssignment[]

  @@map("processes")
}

model ProcessUser {
  id              String  @id @default(cuid())
  processId       String
  userId          String
  processStepCode String? // support for assigner to step

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createAt DateTime @default(now())

  // ProcessStep ProcessStep? @relation(fields: [processId, processStepCode], references: [processId, stepCode])
  @@map("process_users")
}

model OnboardingProcess {
  processId     String     @id
  personalEmail String
  username      String?
  laborType     LaborType? // Loại lao động: In-house, CTV, vendor

  process Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("process_onboard")
}

enum StepType {
  APPROVAL // Approval step
  REVIEW // Review step
  VIEW // Review step
  // VALIDATION // Validation step
  // PAYMENT // Payment processing step
  // NOTIFICATION // Notification step
  ACTION // Custom step
}

enum StepStatus {
  PENDING // Step is pending
  IN_PROGRESS // Step is in progress
  APPROVED // Đã duyệt
  COMPLETED // Step is completed
  REJECTED // Step is rejected
  SKIPPED // Step is skipped
  BLOCKED // Step is blocked by dependencies
}

model ProcessStep {
  id          String  @id @default(cuid())
  processId   String
  process     Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  processType String // e.g., "Payment"

  // Step Information
  stepCode      String // Unique step identifier within workflow
  name          String // Step name
  description   String? // Step description
  type          StepType // Step type
  status        StepStatus @default(BLOCKED) // Step status
  order         Int        @default(0) // Thứ tự duyệt
  isFinal       Boolean    @default(false) // Có phải bước cuối không
  disableRevert Boolean    @default(false) // co bi chan revert khong

  // Assignment Information
  assignedTo String? // User assigned to this step
  assignee   User?   @relation("StepAssignee", fields: [assignedTo], references: [id])
  // assignedUsers ProcessUser[] // Nhiều user chịu trách nhiệm
  // approvalStatus ApprovalStatus @default(PENDING)

  // Execution Information
  startedAt   DateTime?
  completedAt DateTime?
  completedBy String?
  completer   User?     @relation("StepCompleter", fields: [completedBy], references: [id])
  comments    String? // Comments from the user who completed the step
  dueDate     DateTime?

  // Action Configuration
  availableActions String[] // Available actions for this step

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  SettlementForm    SettlementForm[]
  WorkflowChecklist WorkflowChecklist[]

  @@unique([processId, stepCode])
  @@map("process_steps")
}

