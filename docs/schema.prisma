  updated          DateTime @map("updated")

  // ===== BỔ SUNG: Đánh dấu issue manual =====
  isManual Boolean @default(false) @map("isManual") // true = sinh tự động, không sync từ Jira

  issue JiraIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JiraAuthor {
