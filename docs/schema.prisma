  employee   EmployeeProfile? @relation("EvaluatedEmployee", fields: [employeeId], references: [id])

  candidateId String?             @map("candidate_id")
  candidate   sourcing_candidate? @relation(fields: [candidateId], references: [id])

  role  String? // Vai trò trong dự án
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([evaluationId])
  @@index([employeeId]) // ✅ FIXED: Added
  @@index([candidateId]) // ✅ FIXED: Added
  @@map("evaluation_members")
}

